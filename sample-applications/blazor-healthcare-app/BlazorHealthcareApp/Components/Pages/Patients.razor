@page "/patients"
@rendermode InteractiveServer
@inject NavigationManager Nav

<style>
    /* ========== HEADING ========== */
    .hc-heading {
        display: flex; align-items: flex-start; justify-content: space-between;
        gap: 16px; width: 100%; position: relative; z-index: 1; flex-wrap: wrap;
    }
    .hc-heading-text { display: flex; flex-direction: column; gap: 8px; }
    .hc-heading h1 {
        font-weight: 600; font-size: 42px; line-height: 120%;
        color: #232A36; margin: 0;
    }
    .hc-heading p {
        font-weight: 400; font-size: 16px; line-height: 150%;
        color: #4A5666; margin: 0;
    }
    .hc-heading-actions { display: flex; gap: 12px; align-items: center; flex-shrink: 0; }

    .hc-btn-primary {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 10px 20px;
        background: #334155; border: 1px solid #334155;
        border-radius: 9999px; color: #FFFFFF;
        font-family: 'Poppins', sans-serif;
        font-size: 16px; font-weight: 400; line-height: 150%;
        cursor: pointer; white-space: nowrap;
    }
    .hc-btn-primary:hover { background: #1e293b; }
    .hc-btn-primary svg { width: 16px; height: 16px; }

    .hc-btn-secondary {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 10px 20px;
        background: #F3F5F7; border: 1px solid rgba(23, 56, 99, 0.08);
        border-radius: 9999px; color: #232A36;
        font-family: 'Poppins', sans-serif;
        font-size: 16px; font-weight: 400; line-height: 150%;
        cursor: pointer; white-space: nowrap;
    }
    .hc-btn-secondary:hover { background: #E2E8F0; }
    .hc-btn-secondary svg { width: 16px; height: 16px; }

    /* ========== MAIN CONTENT ========== */
    .hc-patients-main {
        display: flex; gap: 0; width: 100%; position: relative; z-index: 1;
        min-height: 0; flex: 1;
    }

    /* ========== GRID CARD ========== */
    .hc-grid-card {
        flex: 1; min-width: 0;
        background: #FFFFFF;
        box-shadow: 0px 1px 3px rgba(0, 0, 0, 0.04), 0px 2px 6px -1px rgba(0, 0, 0, 0.06);
        border-radius: 16px;
        border: 1px solid rgba(23, 56, 99, 0.08);
        overflow: hidden;
        position: relative; z-index: 1;
        transition: flex 0.3s ease;
    }

    /* ========== GRID OVERRIDES ========== */
    .hc-grid-card .k-grid {
        border: none; font-family: 'Poppins', sans-serif;
    }
    .hc-grid-card .k-grid-header .k-header,
    .hc-grid-card .k-grid-header .k-table-th {
        background: #F9FAFB !important;
        border-bottom: 1px solid rgba(23, 56, 99, 0.08);
        border-right: none;
        font-weight: 700; font-size: 14px; color: #232A36;
        padding: 14px 16px;
        white-space: nowrap;
    }
    .hc-grid-card .k-grid-header {
        border-bottom: 1px solid rgba(23, 56, 99, 0.08);
    }
    .hc-grid-card .k-filter-row,
    .hc-grid-card .k-filter-row .k-table-th {
        background: #F9FAFB !important;
        border-bottom: 1px solid rgba(23, 56, 99, 0.08);
        border-right: none;
        padding: 8px 16px;
    }
    .hc-grid-card .k-filter-row .k-filtercell .k-filtercell-wrapper {
        gap: 4px;
    }
    .hc-grid-card .k-filter-row input.k-input-inner {
        font-family: 'Poppins', sans-serif;
        font-size: 14px; color: #232A36;
        padding: 4px 8px;
    }
    .hc-grid-card .k-grid td,
    .hc-grid-card .k-grid .k-table-td {
        padding: 8px 16px !important;
        font-size: 14px; color: #232A36;
        border-bottom: none !important;
        border-right: none;
        vertical-align: middle;
    }
    .hc-grid-card .k-master-row { height: 48px; }
    .hc-grid-card .k-master-row:nth-child(even) td,
    .hc-grid-card .k-master-row:nth-child(even) .k-table-td {
        background: rgba(56, 66, 80, 0.05);
    }
    .hc-grid-card .k-master-row:nth-child(odd) td,
    .hc-grid-card .k-master-row:nth-child(odd) .k-table-td {
        background: #FFFFFF;
    }
    .hc-grid-card .k-master-row:hover td,
    .hc-grid-card .k-master-row:hover .k-table-td {
        background: rgba(99, 102, 251, 0.06) !important;
        cursor: pointer;
    }
    .hc-grid-card .k-grid-content { overflow-y: auto; }
    .hc-grid-card .k-grid-header { padding-right: 0 !important; }
    .hc-grid-card .k-grid .k-pager {
        border-top: 1px solid rgba(23, 56, 99, 0.08);
        background: #FFFFFF;
        font-family: 'Poppins', sans-serif;
        font-size: 14px; color: #4A5666;
        padding: 8px 16px;
    }
    .hc-grid-card .k-pager .k-pager-numbers .k-button.k-selected {
        background: #334155; color: #FFFFFF; border-color: #334155;
    }
    .hc-grid-card .k-selected td,
    .hc-grid-card .k-selected .k-table-td {
        background: rgba(99, 102, 251, 0.08) !important;
    }

    /* ========== PATIENT NAME CELL ========== */
    .hc-patient-cell { display: flex; align-items: center; gap: 10px; }
    .hc-avatar-sm {
        width: 32px; height: 32px; min-width: 32px; border-radius: 9999px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex; align-items: center; justify-content: center;
        color: #FFFFFF; font-weight: 600; font-size: 12px;
        overflow: hidden;
    }
    .hc-patient-cell-name { font-weight: 400; font-size: 14px; color: #232A36; white-space: nowrap; }

    /* ========== STATUS CHIPS ========== */
    .hc-chip {
        display: inline-flex; align-items: center; justify-content: center;
        padding: 4px 12px; border-radius: 9999px;
        font-size: 12px; font-weight: 500; line-height: 133%; white-space: nowrap;
        border: 1px solid;
    }
    .hc-chip-critical { background: #FCDDDA; border-color: #F76F60; color: #7A0C00; }
    .hc-chip-monitoring { background: #FFF4D3; border-color: #FFD760; color: #5E4700; }
    .hc-chip-stable { background: #DCF0D3; border-color: #81D15F; color: #1C5A00; }

    /* ========== VIEW PROFILE BUTTON ========== */
    .hc-view-btn {
        display: inline-flex; align-items: center; gap: 4px;
        padding: 6px 14px;
        background: #F3F5F7; border: 1px solid rgba(23, 56, 99, 0.08);
        border-radius: 9999px; cursor: pointer;
        font-family: 'Poppins', sans-serif;
        font-size: 13px; color: #232A36; white-space: nowrap;
    }
    .hc-view-btn:hover { background: #E2E8F0; }
    .hc-view-btn svg { width: 14px; height: 14px; }

    /* ========== AI SIDE PANEL ========== */
    .hc-ai-panel {
        width: 380px; min-width: 340px; max-width: 380px;
        background: #FFFFFF;
        border: 1px solid rgba(23, 56, 99, 0.08);
        border-radius: 16px;
        box-shadow: 0px 1px 3px rgba(0, 0, 0, 0.04), 0px 2px 6px -1px rgba(0, 0, 0, 0.06);
        display: flex; flex-direction: column;
        overflow: hidden;
        margin-left: 16px;
        position: relative; z-index: 1;
    }
    .hc-ai-panel-header {
        padding: 14px 20px;
        background: #FFFFFF;
        color: #232A36;
        display: flex; align-items: center; gap: 10px;
        flex-shrink: 0;
        border-bottom: 1px solid rgba(23, 56, 99, 0.08);
    }
    .hc-ai-panel-header-icon {
        width: 24px; height: 24px; min-width: 24px;
        display: flex; align-items: center; justify-content: center;
    }
    .hc-ai-panel-header-icon svg { width: 20px; height: 20px; }
    .hc-ai-panel-header-text { display: flex; flex-direction: column; flex: 1; }
    .hc-ai-panel-header-title { font-weight: 700; font-size: 15px; line-height: 140%; color: #232A36; }
    .hc-ai-panel-header-sub { display: none; }
    .hc-ai-panel-close {
        background: none; border: none; cursor: pointer;
        color: #94A3B8;
        width: 32px; height: 32px;
        display: flex; align-items: center; justify-content: center;
        border-radius: 8px;
        transition: background 0.2s ease, color 0.2s ease;
    }
    .hc-ai-panel-close:hover { background: rgba(35, 42, 54, 0.06); color: #232A36; }
    .hc-ai-panel-close svg { width: 16px; height: 16px; }

    .hc-ai-panel-welcome {
        text-align: center;
        padding: 24px 20px 8px;
        display: flex; flex-direction: column; align-items: center; gap: 8px;
    }
    .hc-ai-panel-welcome-date {
        font-size: 12px; color: #94A3B8;
        background: #F1F5F9; border-radius: 9999px;
        padding: 4px 12px;
    }
    .hc-ai-panel-welcome-greeting {
        font-size: 14px; color: #232A36; line-height: 160%;
    }
    .hc-ai-panel-welcome-greeting strong { display: block; font-size: 16px; margin-bottom: 4px; }

    /* TelerikChat overrides for patients AI panel */
    .hc-ai-panel .k-chat {
        border: none;
        border-radius: 0 0 16px 16px;
        font-family: 'Poppins', sans-serif;
        background: #FFFFFF;
    }
    .hc-ai-panel .k-chat .k-message-list {
        background: #FFFFFF;
    }
    .hc-ai-panel .k-chat .k-bubble {
        border-radius: 16px;
        font-size: 14px;
        line-height: 160%;
        font-family: 'Poppins', sans-serif;
    }
    .hc-ai-panel .k-chat .k-message-group-receiver .k-bubble {
        background: #F8FAFC;
        border: 1px solid rgba(23, 56, 99, 0.08);
        color: #232A36;
        border-bottom-left-radius: 4px;
    }
    .hc-ai-panel .k-chat .k-message-group-sender .k-bubble {
        background: #2D3655;
        border: none;
        color: #FFFFFF;
        border-bottom-right-radius: 4px;
    }
    .hc-ai-panel .k-chat .k-quick-replies .k-quick-reply {
        border-radius: 9999px;
        padding: 8px 14px;
        font-family: 'Poppins', sans-serif;
        font-size: 13px;
        color: #334155;
        border: 1px solid rgba(23, 56, 99, 0.12);
        background: #FFFFFF;
    }
    .hc-ai-panel .k-chat .k-quick-replies .k-quick-reply:hover {
        background: #F1F5F9;
        border-color: rgba(99, 102, 251, 0.3);
    }
    .hc-ai-panel .k-chat .k-message-box-wrapper {
        border-top: 1px solid rgba(23, 56, 99, 0.08);
        padding: 8px 12px;
    }
    .hc-ai-panel .k-chat .k-prompt-box {
        font-family: 'Poppins', sans-serif;
        border: 1px solid rgba(23, 56, 99, 0.12);
        border-radius: 12px;
        background: #F9FAFB;
    }
    .hc-ai-panel .k-chat .k-prompt-box:focus-within {
        border-color: rgba(99, 102, 251, 0.4);
        box-shadow: 0 0 0 2px rgba(99, 102, 251, 0.1);
    }
    .hc-ai-panel .k-chat .k-prompt-box-textarea.k-input-inner {
        font-family: 'Poppins', sans-serif;
        font-size: 14px;
        color: #232A36;
    }
    .hc-ai-panel .k-chat .k-suggestion {
        border-radius: 9999px;
    }
    .hc-ai-panel .k-chat .k-message-author {
        display: none;
    }
    .hc-ai-panel .k-chat .k-timestamp {
        display: none;
    }
    .hc-ai-panel .k-chat .k-no-avatar {
        margin-left: 0;
    }

    /* Active AI button state */
    .hc-btn-ai-active {
        background: linear-gradient(135deg, #AC58FF 0%, #4B5FFA 100%) !important;
        border-color: transparent !important;
        color: #FFFFFF !important;
    }

    /* ========== RESPONSIVE ========== */
    @@media (max-width: 1200px) {
        .hc-patients-main { flex-direction: column; }
        .hc-ai-panel {
            width: 100%; max-width: 100%; min-width: 0;
            margin-left: 0; margin-top: 16px;
            border-radius: 16px;
            max-height: 500px;
        }
        .hc-grid-card { border-radius: 16px; }
    }

    @@media (max-width: 960px) {
        .hc-heading h1 { font-size: 32px; }
    }

    @@media (max-width: 640px) {
        .hc-heading { gap: 12px; }
        .hc-heading h1 { font-size: 26px; }
        .hc-heading p { font-size: 14px; }
        .hc-heading-actions { width: 100%; }
        .hc-btn-primary, .hc-btn-secondary { flex: 1; justify-content: center; font-size: 14px; padding: 8px 14px; }
    }
</style>

<!-- ========== HEADING ========== -->
<div class="hc-heading">
    <div class="hc-heading-text">
        <h1>Patients</h1>
        <p>Monitor patient trends, vitals, lab results, and risk levels in one place</p>
    </div>
    <div class="hc-heading-actions">
        <button class="hc-btn-primary @(isAIPanelOpen ? "hc-btn-ai-active" : "")" @onclick="ToggleAIPanel">
            <svg viewBox="0 0 16 16" fill="none"><path d="M8 2L9.1 5.5H12.8L9.85 7.7L10.9 11.2L8 9L5.1 11.2L6.15 7.7L3.2 5.5H6.9L8 2Z" stroke="white" stroke-width="1.2" fill="none" stroke-linejoin="round"/></svg>
            AI Assistance
        </button>
        <button class="hc-btn-secondary">
            <svg viewBox="0 0 16 16" fill="none"><path d="M8 10V2M8 10L5 7M8 10L11 7" stroke="#232A36" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round"/><path d="M2 12V13C2 13.55 2.45 14 3 14H13C13.55 14 14 13.55 14 13V12" stroke="#232A36" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Export
        </button>
    </div>
</div>

<!-- ========== MAIN: GRID + DRILLDOWN ========== -->
<div class="hc-patients-main">
    <!-- GRID CARD -->
    <div class="hc-grid-card">
        <TelerikGrid Data="@PatientData"
                     TItem="PatientModel"
                     Pageable="true"
                     @bind-PageSize="@PageSize"
                     @bind-Page="@CurrentPage"
                     Sortable="true"
                     Resizable="true"
                     FilterMode="@GridFilterMode.FilterRow"
                     OnRowClick="@OnRowClick"
                     Height="100%">
            <GridSettings>
                <GridPagerSettings PageSizes="@(new List<int?> { 5, 10, 20 })" InputType="@PagerInputType.Buttons" ButtonCount="5" />
            </GridSettings>
            <GridColumns>
                <GridColumn Field="@nameof(PatientModel.Name)" Title="Patient Name" Width="220px">
                    <Template>
                        @{
                            var p = (PatientModel)context;
                        }
                        <div class="hc-patient-cell">
                            <div class="hc-avatar-sm">@p.Initials</div>
                            <span class="hc-patient-cell-name">@p.Name</span>
                        </div>
                    </Template>
                </GridColumn>
                <GridColumn Field="@nameof(PatientModel.Age)" Title="Age" Width="80px" />
                <GridColumn Field="@nameof(PatientModel.Status)" Title="Status" Width="140px">
                    <Template>
                        @{
                            var p = (PatientModel)context;
                            var chipClass = p.Status switch
                            {
                                "Critical" => "hc-chip-critical",
                                "Monitoring" => "hc-chip-monitoring",
                                _ => "hc-chip-stable"
                            };
                        }
                        <span class="hc-chip @chipClass">@p.Status</span>
                    </Template>
                </GridColumn>
                <GridColumn Field="@nameof(PatientModel.Gender)" Title="Gender" Width="100px" />
                <GridColumn Field="@nameof(PatientModel.BloodType)" Title="Blood Type" Width="110px" />
                <GridColumn Field="@nameof(PatientModel.Ward)" Title="Ward" Width="130px" />
                <GridColumn Field="@nameof(PatientModel.Diagnosis)" Title="Diagnosis" />
                <GridColumn Field="@nameof(PatientModel.Id)" Title="Actions" Width="160px" Filterable="false" Sortable="false">
                    <Template>
                        @{
                            var p = (PatientModel)context;
                            var profileUrl = $"/patient/{p.Id}";
                        }
                        <button class="hc-view-btn" @onclick="@(() => Nav.NavigateTo(profileUrl))" @onclick:stopPropagation="true">
                            <svg viewBox="0 0 16 16" fill="none"><path d="M1 8C1 8 3.5 3 8 3C12.5 3 15 8 15 8C15 8 12.5 13 8 13C3.5 13 1 8 1 8Z" stroke="#232A36" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="8" cy="8" r="2.5" stroke="#232A36" stroke-width="1.2"/></svg>
                            View Profile
                        </button>
                    </Template>
                </GridColumn>
            </GridColumns>
        </TelerikGrid>
    </div>    <!-- AI ASSISTANT SIDE PANEL -->
    @if (isAIPanelOpen)
    {
        <div class="hc-ai-panel">
            <div class="hc-ai-panel-header">
                <div class="hc-ai-panel-header-icon">
                    <svg viewBox="0 0 20 20" fill="none"><path d="M10 1l1.5 4.5L16 7l-4.5 1.5L10 13l-1.5-4.5L4 7l4.5-1.5L10 1z" fill="#7C5CFC" opacity="0.9"/><path d="M15 11l1 3 3 1-3 1-1 3-1-3-3-1 3-1 1-3z" fill="#7C5CFC" opacity="0.7"/><path d="M4 12l.75 2.25L7 15l-2.25.75L4 18l-.75-2.25L1 15l2.25-.75L4 12z" fill="#7C5CFC" opacity="0.5"/></svg>
                </div>
                <div class="hc-ai-panel-header-text">
                    <span class="hc-ai-panel-header-title">AI Assistant</span>
                    <span class="hc-ai-panel-header-sub">Patient Discovery Insights</span>
                </div>
                <button class="hc-ai-panel-close" @onclick="ToggleAIPanel">
                    <svg viewBox="0 0 16 16" fill="none"><path d="M4 4L12 12M12 4L4 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </button>
            </div>

            <TelerikChat @ref="aiChatRef"
                         Data="@aiChatData"
                         AuthorId="@("user")"
                         Suggestions="@aiChatSuggestions"
                         OnSendMessage="@OnAIChatSendMessage"
                         OnSuggestionClick="@OnAIChatSuggestionClick"
                         Placeholder="Type a message"
                         Height="100%"
                         EnableSpeechToText="false"
                         EnableFileUpload="true">
                <ChatSettings>
                    <ChatTextAreaSettings Mode="@PromptBoxMode.MultiLine" Rows="3" MaxTextAreaHeight="120px" />
                </ChatSettings>
                <NoDataTemplate>
                    <div class="hc-ai-panel-welcome">
                        <span class="hc-ai-panel-welcome-date">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</span>
                        <div class="hc-ai-panel-welcome-greeting">
                            <strong>@("\U0001F44B") Hello! I'm your AI Assistant.</strong>
                            I can help you with your daily clinical tasks, patient information, and quick actions. Try one of the suggestions below!
                        </div>
                    </div>
                </NoDataTemplate>
            </TelerikChat>
        </div>
    }
</div>

@code {
    private int PageSize = 10;
    private int CurrentPage = 1;

    private bool isAIPanelOpen;
    private TelerikChat<PatientAIChatMsg> aiChatRef = null!;
    private List<PatientAIChatMsg> aiChatData = new();
    private List<string> aiChatSuggestions = new() { "Summarize patient history", "Highlight risk" };

    private List<PatientModel> PatientData = new();

    protected override void OnInitialized()
    {
        PatientData = GeneratePatients();
    }

    private void OnRowClick(GridRowClickEventArgs args)
    {
        if (args.Item is PatientModel patient)
        {
            Nav.NavigateTo($"/patient/{patient.Id}");
        }
    }

    // ========== AI SIDE PANEL ==========

    private void ToggleAIPanel()
    {
        isAIPanelOpen = !isAIPanelOpen;
        if (!isAIPanelOpen)
        {
            aiChatData.Clear();
            aiChatSuggestions = new() { "Summarize patient history", "Highlight risk" };
        }
    }

    private async Task OnAIChatSuggestionClick(ChatSuggestionClickEventArgs args)
    {
        var suggestion = args.Suggestion;
        var userText = suggestion switch
        {
            "Summarize patient history" => "Can you summarize the patient list?",
            "Highlight risk" => "Identify high-risk patients",
            _ => suggestion
        };

        aiChatData.Add(new PatientAIChatMsg { Id = Guid.NewGuid().ToString(), Text = userText, AuthorId = "user", AuthorName = "Dr. Carter", Timestamp = DateTime.Now });
        aiChatSuggestions = new();

        var typingMsg = new PatientAIChatMsg { Id = "typing", Text = "", AuthorId = "ai", AuthorName = "AI Assistant", IsTyping = true, Timestamp = DateTime.Now };
        aiChatData.Add(typingMsg);
        StateHasChanged();

        await Task.Delay(1200);
        aiChatData.Remove(typingMsg);

        var response = suggestion switch
        {
            "Summarize patient history" => $"You currently have {PatientData.Count} patients across multiple wards. {PatientData.Count(p => p.Status == "Critical")} patients are in critical status, {PatientData.Count(p => p.Status == "Monitoring")} are being monitored, and {PatientData.Count(p => p.Status == "Stable")} are stable. Key focus areas: Cardiology ({PatientData.Count(p => p.Ward == "Cardiology")} patients) and Neurology ({PatientData.Count(p => p.Ward == "Neurology")} patients).",
            "Highlight risk" => BuildHighRiskResponse(),
            _ => "I'm sorry, I don't have information for that query."
        };

        aiChatData.Add(new PatientAIChatMsg { Id = Guid.NewGuid().ToString(), Text = response, AuthorId = "ai", AuthorName = "AI Assistant", Timestamp = DateTime.Now });
    }

    private async Task OnAIChatSendMessage(ChatSendMessageEventArgs args)
    {
        var text = args.Message?.Trim();
        if (string.IsNullOrEmpty(text)) return;

        aiChatData.Add(new PatientAIChatMsg { Id = Guid.NewGuid().ToString(), Text = text, AuthorId = "user", AuthorName = "Dr. Carter", Timestamp = DateTime.Now });
        aiChatSuggestions = new();

        var typingMsg = new PatientAIChatMsg { Id = "typing", Text = "", AuthorId = "ai", AuthorName = "AI Assistant", IsTyping = true, Timestamp = DateTime.Now };
        aiChatData.Add(typingMsg);
        StateHasChanged();

        await Task.Delay(1000);
        aiChatData.Remove(typingMsg);

        var lower = text.ToLowerInvariant();
        string response;
        if (lower.Contains("risk") || lower.Contains("critical") || lower.Contains("high-risk"))
            response = BuildHighRiskResponse();
        else if (lower.Contains("summary") || lower.Contains("summarize") || lower.Contains("list") || lower.Contains("overview"))
            response = $"You currently have {PatientData.Count} patients across multiple wards. {PatientData.Count(p => p.Status == "Critical")} patients are in critical status, {PatientData.Count(p => p.Status == "Monitoring")} are being monitored, and {PatientData.Count(p => p.Status == "Stable")} are stable.";
        else if (lower.Contains("allerg"))
        {
            var withAllergies = PatientData.Where(p => p.Allergies.Any()).ToList();
            response = $"{withAllergies.Count} patients have known allergies: " + string.Join("; ", withAllergies.Select(p => $"{p.Name} ({string.Join(", ", p.Allergies)})")) + ". Verify allergy bands before administering medication.";
        }
        else
            response = "I can help with patient summaries, risk analysis, allergy checks, and clinical insights. Try asking about a specific topic!";

        aiChatData.Add(new PatientAIChatMsg { Id = Guid.NewGuid().ToString(), Text = response, AuthorId = "ai", AuthorName = "AI Assistant", Timestamp = DateTime.Now });
    }

    private string BuildHighRiskResponse()
    {
        var critical = PatientData.Where(p => p.Status == "Critical").ToList();
        if (!critical.Any()) return "No patients currently in critical status. All patients are stable or being monitored.";

        var lines = critical.Select(p =>
            $"\u2022 {p.Name} ({p.Age}{(p.Gender == "Male" ? "M" : "F")}, {p.Ward}) \u2014 {p.Diagnosis}. " +
            (p.BpSystolic > 140 ? $"BP {p.BpSystolic}/{p.BpDiastolic} (elevated). " : "") +
            (p.HeartRate > 100 ? $"HR {p.HeartRate} bpm (tachycardia). " : "") +
            (p.O2Saturation < 95 ? $"SpO\u2082 {p.O2Saturation}% (low). " : "")
        );

        return $"Based on current vitals and status, {critical.Count} patient(s) show elevated risk levels:\n\n" + string.Join("\n", lines) + "\n\nRecommend frequent monitoring and immediate clinical review.";
    }

    // ========== MODELS ==========

    public class PatientModel
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Initials { get; set; } = "";
        public int Age { get; set; }
        public string Status { get; set; } = "";
        public string Gender { get; set; } = "";
        public string BloodType { get; set; } = "";
        public string Ward { get; set; } = "";
        public string Diagnosis { get; set; } = "";

        // Drilldown detail fields
        public int HeartRate { get; set; }
        public int BpSystolic { get; set; }
        public int BpDiastolic { get; set; }
        public decimal Temperature { get; set; }
        public int O2Saturation { get; set; }
        public List<string> Allergies { get; set; } = new();
        public List<LabResult> LabResults { get; set; } = new();
        public List<Medication> Medications { get; set; } = new();
        public List<Visit> RecentVisits { get; set; } = new();
    }

    public class LabResult
    {
        public string Test { get; set; } = "";
        public string Value { get; set; } = "";
        public string RefRange { get; set; } = "";
        public bool IsNormal { get; set; }
    }

    public class Medication
    {
        public string Name { get; set; } = "";
        public string Dosage { get; set; } = "";
    }

    public class Visit
    {
        public string Date { get; set; } = "";
        public string Reason { get; set; } = "";
        public string Doctor { get; set; } = "";
    }

    public class PatientAIChatMsg
    {
        public string Id { get; set; } = "";
        public string Text { get; set; } = "";
        public string AuthorId { get; set; } = "";
        public string AuthorName { get; set; } = "";
        public DateTime Timestamp { get; set; }
        public bool IsTyping { get; set; }
    }

