@page "/patient/{PatientId:int}"
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject PatientService PatientService
@using BlazorHealthcareApp.Models
@using BlazorHealthcareApp.Services

<style>
    /* ========== PAGE SCOPED CONTAINER ========== */
    .hc-pd-page {
        display: flex; flex-direction: column; gap: 20px;
    }
    .hc-pd-page * { pointer-events: auto; }

    /* ========== BREADCRUMB ========== */
    .hc-pd-breadcrumb {
        display: flex; align-items: center; gap: 8px;
        font-size: 14px; color: #4A5666; width: 100%;
        position: relative; z-index: 1;
    }
    .hc-pd-breadcrumb a {
        color: #4A5666; text-decoration: none; display: flex; align-items: center; gap: 4px;
    }
    .hc-pd-breadcrumb a:hover { color: #232A36; }
    .hc-pd-breadcrumb svg { width: 14px; height: 14px; }
    .hc-pd-breadcrumb-sep { color: #94A3B8; }
    .hc-pd-breadcrumb-current { color: #232A36; font-weight: 500; display: flex; align-items: center; gap: 4px; }
    .hc-pd-breadcrumb-current svg { width: 14px; height: 14px; }

    /* ========== HEADER ROW (3 cards) ========== */
    .hc-pd-header {
        display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 32px;
        width: 100%; position: relative; z-index: 1;
    }
    .hc-pd-header-card {
        background: #FFFFFF;
        box-shadow: 0px 1px 3px rgba(0, 0, 0, 0.04), 0px 2px 6px -1px rgba(0, 0, 0, 0.06);
        border-radius: 16px;
        padding: 20px 24px;
        display: flex; flex-direction: column; gap: 14px;
    }

    /* Basic Info card */
    .hc-pd-profile-row { display: flex; align-items: center; gap: 14px; justify-content: space-between; }
    .hc-pd-profile-left { display: flex; align-items: center; gap: 12px; }
    .hc-pd-avatar {
        width: 56px; height: 56px; min-width: 56px; border-radius: 9999px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex; align-items: center; justify-content: center;
        color: #FFFFFF; font-weight: 600; font-size: 20px;
        overflow: hidden; flex-shrink: 0;
    }
    .hc-pd-profile-info { display: flex; flex-direction: column; gap: 3px; }
    .hc-pd-name { font-weight: 600; font-size: 18px; color: #232A36; line-height: 130%; }
    .hc-pd-chip {
        display: inline-flex; align-items: center; justify-content: center;
        padding: 3px 10px; border-radius: 9999px;
        font-size: 12px; font-weight: 500; line-height: 133%; white-space: nowrap;
        border: 1px solid; width: fit-content;
    }
    .hc-pd-chip-critical { background: #FCDDDA; border-color: #F76F60; color: #7A0C00; }
    .hc-pd-chip-monitoring { background: #FFF4D3; border-color: #FFD760; color: #5E4700; }
    .hc-pd-chip-stable { background: #DCF0D3; border-color: #81D15F; color: #1C5A00; }

    .hc-pd-basic-title { font-weight: 700; font-size: 14px; color: #232A36; margin: 0; }
    .hc-pd-basic-grid { display: flex; flex-direction: column; gap: 6px; }
    .hc-pd-basic-row { display: flex; justify-content: space-between; align-items: center; }
    .hc-pd-basic-label { font-size: 14px; color: #4A5666; }
    .hc-pd-basic-value { font-size: 14px; color: #232A36; font-weight: 500; }

    /* Vitals header card */
    .hc-pd-vitals-title { font-weight: 700; font-size: 14px; color: #232A36; margin: 0; }
    .hc-pd-vitals-grid { display: flex; flex-direction: column; gap: 6px; }
    .hc-pd-vitals-row { display: flex; justify-content: space-between; align-items: center; }
    .hc-pd-vitals-label { font-size: 13px; color: #4A5666; }
    .hc-pd-vitals-value { font-size: 13px; font-weight: 500; color: #232A36; }
    .hc-pd-vitals-value-critical { color: #E53E3E; }

    /* Admission card */
    .hc-pd-admission-title { font-weight: 700; font-size: 14px; color: #232A36; margin: 0; }
    .hc-pd-admission-grid { display: flex; flex-direction: column; gap: 6px; }
    .hc-pd-admission-row { display: flex; justify-content: space-between; align-items: center; }
    .hc-pd-admission-label { font-size: 13px; color: #4A5666; }
    .hc-pd-admission-value { font-size: 13px; color: #232A36; font-weight: 500; }

    /* ========== CARDS ========== */
    .hc-pd-card {
        background: #FFFFFF;
        box-shadow: 0px 1px 3px rgba(0, 0, 0, 0.04), 0px 2px 6px -1px rgba(0, 0, 0, 0.06);
        border-radius: 16px;
        padding: 24px;
        position: relative; z-index: 1;
        width: 100%;
    }
    .hc-pd-card-header {
        display: flex; justify-content: space-between; align-items: center;
        margin-bottom: 16px;
    }
    .hc-pd-card-title { font-weight: 700; font-size: 18px; color: #232A36; margin: 0; }

    .hc-pd-save-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 16px;
        background: #F3F5F7; border: 1px solid rgba(23, 56, 99, 0.08);
        border-radius: 9999px; cursor: pointer;
        font-family: 'Poppins', sans-serif;
        font-size: 13px; color: #232A36; white-space: nowrap;
    }
    .hc-pd-save-btn:hover { background: #E2E8F0; }
    .hc-pd-save-btn svg { width: 14px; height: 14px; }

    /* ========== EDITOR OVERRIDES ========== */
    .hc-pd-page .hc-pd-editor-wrapper .k-editor {
        border: 1px solid rgba(23, 56, 99, 0.08);
        border-radius: 16px;
        font-family: 'Poppins', sans-serif;
        overflow: hidden;
    }
    .hc-pd-page .hc-pd-editor-wrapper .k-editor .k-editor-toolbar {
        background: #F9FAFB;
        border-bottom: 1px solid rgba(23, 56, 99, 0.08);
        padding: 8px 12px;
    }
    .hc-pd-page .hc-pd-editor-wrapper .k-editor .k-editable-area {
        font-family: 'Poppins', sans-serif;
        font-size: 14px; color: #232A36;
        line-height: 170%;
    }



    /* ========== LAB RESULTS GRID ========== */
    .hc-pd-page .hc-pd-lab-grid .k-grid {
        border: 1px solid rgba(23, 56, 99, 0.08);
        border-radius: 16px;
        font-family: 'Poppins', sans-serif;
        overflow: hidden;
    }
    .hc-pd-page .hc-pd-lab-grid .k-grid-header .k-header,
    .hc-pd-page .hc-pd-lab-grid .k-grid-header .k-table-th {
        background: #F9FAFB !important;
        border-bottom: 1px solid rgba(23, 56, 99, 0.08);
        border-right: none;
        font-weight: 700; font-size: 13px; color: #232A36;
        padding: 12px 16px;
    }
    .hc-pd-page .hc-pd-lab-grid .k-grid-header {
        border-bottom: 1px solid rgba(23, 56, 99, 0.08);
    }
    .hc-pd-page .hc-pd-lab-grid .k-grid td,
    .hc-pd-page .hc-pd-lab-grid .k-grid .k-table-td {
        padding: 10px 16px !important;
        font-size: 14px; color: #232A36;
        border-bottom: 1px solid rgba(23, 56, 99, 0.04);
        border-right: none;
        vertical-align: middle;
    }
    .hc-pd-page .hc-pd-lab-grid .k-master-row { height: 44px; }
    .hc-pd-page .hc-pd-lab-grid .k-master-row:hover td,
    .hc-pd-page .hc-pd-lab-grid .k-master-row:hover .k-table-td {
        background: rgba(99, 102, 251, 0.04) !important;
    }
    .hc-pd-page .hc-pd-lab-grid .k-grid .k-pager { display: none !important; }
    .hc-pd-page .hc-pd-lab-grid .k-grid-header { padding-right: 0 !important; }

    /* Always show sort arrow indicator in every column header */
    .hc-pd-page .hc-pd-lab-grid .k-header .k-sort-icon,
    .hc-pd-page .hc-pd-lab-grid .k-table-th .k-sort-icon {
        display: inline-flex !important;
        opacity: 0.35;
    }
    .hc-pd-page .hc-pd-lab-grid .k-header .k-sort-icon .k-icon,
    .hc-pd-page .hc-pd-lab-grid .k-table-th .k-sort-icon .k-icon {
        display: inline-flex !important;
    }
    .hc-pd-page .hc-pd-lab-grid .k-sorted .k-sort-icon {
        opacity: 1;
    }
    /* Remove vertical scrollbar */
    .hc-pd-page .hc-pd-lab-grid .k-grid-content {
        overflow: hidden !important;
    }
    .hc-pd-page .hc-pd-lab-grid .k-grid-header-wrap {
        border-right: none !important;
    }
    /* Custom sort arrow in header */
    .hc-pd-sort-arrow {
        display: inline-flex; align-items: center; margin-left: 2px; opacity: 0.45;
    }
    .hc-pd-sort-arrow svg { width: 10px; height: 10px; }
    /* Equal-width columns */
    .hc-pd-page .hc-pd-lab-grid .k-grid .k-table { table-layout: fixed; width: 100%; }
    .hc-pd-page .hc-pd-lab-grid .k-grid-header .k-table { table-layout: fixed; width: 100%; }

    .hc-pd-lab-chip {
        display: inline-flex; align-items: center; justify-content: center;
        padding: 3px 10px; border-radius: 9999px;
        font-size: 12px; font-weight: 500; white-space: nowrap; border: 1px solid;
    }
    .hc-pd-lab-critical { background: #FCDDDA; border-color: #F76F60; color: #7A0C00; }
    .hc-pd-lab-monitoring { background: #FFF4D3; border-color: #FFD760; color: #5E4700; }
    .hc-pd-lab-stable { background: #DCF0D3; border-color: #81D15F; color: #1C5A00; }

    /* ========== RESPONSIVE ========== */
    @@media (max-width: 1200px) {
        .hc-pd-header { grid-template-columns: 1fr; }
    }

    @@media (max-width: 640px) {
        .hc-pd-name { font-size: 18px; }
        .hc-pd-avatar { width: 48px; height: 48px; min-width: 48px; font-size: 18px; }
        .hc-pd-card { padding: 16px; }
        .hc-pd-header-card { padding: 16px; }
    }
</style>

<div class="hc-pd-page">
@if (patient != null)
{
    <!-- ========== BREADCRUMB ========== -->
    <div class="hc-pd-breadcrumb">
        <a href="/patients">
            <svg viewBox="0 0 16 16" fill="none"><path d="M6.5 12L2.5 8L6.5 4" stroke="currentColor" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Patients
        </a>
        <span class="hc-pd-breadcrumb-sep">&gt;</span>
        <span class="hc-pd-breadcrumb-current">
            <svg viewBox="0 0 16 16" fill="none"><path d="M3 5H13M3 8H9M3 11H11" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Patient Profile
        </span>
    </div>

    <!-- ========== HEADER — 3 CARDS ========== -->
    <div class="hc-pd-header">
        <!-- Basic Information -->
        <div class="hc-pd-header-card">
            <div class="hc-pd-profile-row">
                <div class="hc-pd-profile-left">
                    <div class="hc-pd-avatar">@patient.Initials</div>
                    <span class="hc-pd-name">@patient.Name</span>
                </div>
                @{
                    var chipClass = patient.Status switch
                    {
                        "Critical" => "hc-pd-chip-critical",
                        "Monitoring" => "hc-pd-chip-monitoring",
                        _ => "hc-pd-chip-stable"
                    };
                }
                <span class="hc-pd-chip @chipClass">@patient.Status</span>
            </div>
            <div>
                <div class="hc-pd-basic-title">Basic Information</div>
                <div class="hc-pd-basic-grid" style="margin-top: 8px;">
                    <div class="hc-pd-basic-row">
                        <span class="hc-pd-basic-label">Patient ID</span>
                        <span class="hc-pd-basic-value">P-@patient.Id.ToString("D6")</span>
                    </div>
                    <div class="hc-pd-basic-row">
                        <span class="hc-pd-basic-label">Age/Gender</span>
                        <span class="hc-pd-basic-value">@patient.Age years, @patient.Gender</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Vitals -->
        <div class="hc-pd-header-card">
            <div class="hc-pd-vitals-title">Recent Vitals</div>
            <div class="hc-pd-vitals-grid">
                <div class="hc-pd-vitals-row">
                    <span class="hc-pd-vitals-label">Heart Rate</span>
                    <span class="hc-pd-vitals-value">@patient.HeartRate bpm</span>
                </div>
                <div class="hc-pd-vitals-row">
                    <span class="hc-pd-vitals-label">Blood Pressure</span>
                    <span class="hc-pd-vitals-value">@patient.BpSystolic/@patient.BpDiastolic</span>
                </div>
                <div class="hc-pd-vitals-row">
                    <span class="hc-pd-vitals-label">Temperature</span>
                    <span class="hc-pd-vitals-value">@patient.Temperature</span>
                </div>
                <div class="hc-pd-vitals-row">
                    <span class="hc-pd-vitals-label">O2 Saturation</span>
                    <span class="hc-pd-vitals-value @(patient.O2Saturation < 95 ? "hc-pd-vitals-value-critical" : "")">@(patient.O2Saturation)%</span>
                </div>
                <div class="hc-pd-vitals-row">
                    <span class="hc-pd-vitals-label">Respiratory Rate</span>
                    <span class="hc-pd-vitals-value">@patient.RespiratoryRate breaths/min</span>
                </div>
            </div>
        </div>

        <!-- Admission Details -->
        <div class="hc-pd-header-card">
            <div class="hc-pd-admission-title">Admission Details</div>
            <div class="hc-pd-admission-grid">
                <div class="hc-pd-admission-row">
                    <span class="hc-pd-admission-label">Department</span>
                    <span class="hc-pd-admission-value">@patient.Department</span>
                </div>
                <div class="hc-pd-admission-row">
                    <span class="hc-pd-admission-label">Ward</span>
                    <span class="hc-pd-admission-value">@patient.Ward</span>
                </div>
                <div class="hc-pd-admission-row">
                    <span class="hc-pd-admission-label">Room</span>
                    <span class="hc-pd-admission-value">@patient.Room</span>
                </div>
                <div class="hc-pd-admission-row">
                    <span class="hc-pd-admission-label">Admission Date</span>
                    <span class="hc-pd-admission-value">@patient.AdmissionDate</span>
                </div>
                <div class="hc-pd-admission-row">
                    <span class="hc-pd-admission-label">Assigned Nurse</span>
                    <span class="hc-pd-admission-value">@patient.AssignedNurse</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ========== PATIENT NOTE (full width) ========== -->
    <div class="hc-pd-card">
        <div class="hc-pd-card-header">
            <h3 class="hc-pd-card-title">Patient Note</h3>
            <button class="hc-pd-save-btn">
                <svg viewBox="0 0 16 16" fill="none"><path d="M12.67 2H3.33C2.6 2 2 2.6 2 3.33V12.67C2 13.4 2.6 14 3.33 14H12.67C13.4 14 14 13.4 14 12.67V3.33C14 2.6 13.4 2 12.67 2Z" stroke="#232A36" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/><path d="M11.33 14V9.33H4.67V14" stroke="#232A36" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/><path d="M4.67 2V5.33H10" stroke="#232A36" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Save
            </button>
        </div>
        <div class="hc-pd-editor-wrapper">
            <TelerikEditor @bind-Value="@editorValue" Height="260px" Tools="@EditorTools" />
        </div>
    </div>

    <!-- ========== LAB RESULTS (full width) ========== -->
    <div class="hc-pd-card">
        <div class="hc-pd-card-header">
            <h3 class="hc-pd-card-title">Recent Lab Results</h3>
        </div>
        <div class="hc-pd-lab-grid">
            <TelerikGrid Data="@labResults"
                         TItem="LabResultRow"
                         Sortable="true"
                         Pageable="false">
                <GridColumns>
                    <GridColumn Field="@nameof(LabResultRow.Test)" Title="Test">
                        <HeaderTemplate>
                            Test <span class="hc-pd-sort-arrow"><svg viewBox="0 0 10 10" fill="none"><path d="M5 2V8M5 2L2.5 4.5M5 2L7.5 4.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                        </HeaderTemplate>
                    </GridColumn>
                    <GridColumn Field="@nameof(LabResultRow.Result)" Title="Result">
                        <HeaderTemplate>
                            Result <span class="hc-pd-sort-arrow"><svg viewBox="0 0 10 10" fill="none"><path d="M5 2V8M5 2L2.5 4.5M5 2L7.5 4.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                        </HeaderTemplate>
                    </GridColumn>
                    <GridColumn Field="@nameof(LabResultRow.Reference)" Title="Reference">
                        <HeaderTemplate>
                            Reference <span class="hc-pd-sort-arrow"><svg viewBox="0 0 10 10" fill="none"><path d="M5 2V8M5 2L2.5 4.5M5 2L7.5 4.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                        </HeaderTemplate>
                    </GridColumn>
                    <GridColumn Field="@nameof(LabResultRow.Status)" Title="Status">
                        <HeaderTemplate>
                            Status <span class="hc-pd-sort-arrow"><svg viewBox="0 0 10 10" fill="none"><path d="M5 2V8M5 2L2.5 4.5M5 2L7.5 4.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                        </HeaderTemplate>
                        <Template>
                            @{
                                var lab = (LabResultRow)context;
                                var labChip = lab.Status switch
                                {
                                    "Critical" => "hc-pd-lab-critical",
                                    "Monitoring" => "hc-pd-lab-monitoring",
                                    _ => "hc-pd-lab-stable"
                                };
                            }
                            <span class="hc-pd-lab-chip @labChip">@lab.Status</span>
                        </Template>
                    </GridColumn>
                    <GridColumn Field="@nameof(LabResultRow.Note)" Title="Note">
                        <HeaderTemplate>
                            Note <span class="hc-pd-sort-arrow"><svg viewBox="0 0 10 10" fill="none"><path d="M5 2V8M5 2L2.5 4.5M5 2L7.5 4.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                        </HeaderTemplate>
                    </GridColumn>
                </GridColumns>
            </TelerikGrid>
        </div>
    </div>
}
</div>

@code {
    [Parameter] public int PatientId { get; set; }

    private PatientDetailModel? patient;
    private string editorValue = "";
    private List<LabResultRow> labResults = new();

    private List<IEditorTool> EditorTools = new List<IEditorTool>()
    {
        new Telerik.Blazor.Components.Editor.EditorButtonGroup(
            new Telerik.Blazor.Components.Editor.Bold(),
            new Telerik.Blazor.Components.Editor.Italic(),
            new Telerik.Blazor.Components.Editor.Underline(),
            new Telerik.Blazor.Components.Editor.Strikethrough()
        ),
        new Telerik.Blazor.Components.Editor.FontFamily(),
        new Telerik.Blazor.Components.Editor.FontSize(),
        new Telerik.Blazor.Components.Editor.EditorButtonGroup(
            new Telerik.Blazor.Components.Editor.AlignLeft(),
            new Telerik.Blazor.Components.Editor.AlignCenter(),
            new Telerik.Blazor.Components.Editor.AlignRight(),
            new Telerik.Blazor.Components.Editor.AlignJustify()
        ),
        new Telerik.Blazor.Components.Editor.Format(),
    };

    protected override void OnInitialized()
    {
        patient = PatientService.GetPatientDetail(PatientId);
        if (patient is null)
        {
            Nav.NavigateTo("/patients");
            return;
        }

        editorValue = "<p>Patient reports mild chest discomfort experienced earlier in the morning during light physical activity. " +
            "The pain was described as a brief pressure sensation lasting approximately 3\u20134 minutes and resolved without intervention. " +
            "No associated symptoms such as shortness of breath, dizziness, or nausea were reported.</p>" +
            "<p>Vital signs remain stable, and the patient appears comfortable at rest. Blood pressure slightly elevated but consistent " +
            "with previous readings. ECG results reviewed and show normal sinus rhythm with no acute abnormalities.</p>" +
            "<p>Patient advised to avoid strenuous activity until further evaluation is completed. Continue monitoring vital signs and " +
            "assess for any recurrence of chest discomfort. Follow-up consultation with cardiology scheduled for later today.</p>" +
            "<p>Patient denies any new symptoms and remains stable under observation with no further episodes reported.</p>";

        labResults = new List<LabResultRow>
        {
            new() { Test = "C-Reactive Protein (CRP)",  Result = "18 mg/L",    Reference = "<5.0",    Status = "Critical",   Note = "Significant inflammatory elevation" },
            new() { Test = "LDL Cholesterol",           Result = "162 mg/dL",  Reference = "<100",    Status = "Monitoring", Note = "Above target for cardiac risk patients" },
            new() { Test = "Troponin I",                Result = "0.03 ng/mL", Reference = "<0.004",  Status = "Critical",   Note = "Borderline - serial monitoring ordered" },
            new() { Test = "Hemoglobin A1c",            Result = "5.5%",       Reference = "<5.7",    Status = "Monitoring", Note = "Pre-diabetic range" },
            new() { Test = "eGFR (Kidney Function)",    Result = "78 mL/min",  Reference = ">60",     Status = "Stable",     Note = "Adequate renal function" },
            new() { Test = "Potassium",                 Result = "3.9 mEq/L",  Reference = "3.5-5.0", Status = "Monitoring", Note = "Within normal limits" },
            new() { Test = "C-Reactive Protein (CRP)",  Result = "20 mg/L",    Reference = "<5.9",    Status = "Stable",     Note = "Borderline - serial monitoring ordered" },
            new() { Test = "Hemoglobin A1c",            Result = "178 mg/DI",  Reference = "<0.03",   Status = "Critical",   Note = "Above target for cardiac risk patients" },
            new() { Test = "eGFR (Kidney Function)",    Result = "6.7%",       Reference = "<100",    Status = "Critical",   Note = "Significant inflammatory elevation" },
            new() { Test = "LDL Cholesterol",           Result = "162 mg/dL",  Reference = "4.5-6.0", Status = "Monitoring", Note = "Pre-diabetic range" },
            new() { Test = "C-Reactive Protein (CRP)",  Result = "18 mg/L",    Reference = "<5.0",    Status = "Critical",   Note = "Significant inflammatory elevation" },
        };
    }

    // ========== LOCAL VIEW MODEL (lab results grid only) ==========

    public class LabResultRow
    {
        public string Test { get; set; } = "";
        public string Result { get; set; } = "";
        public string Reference { get; set; } = "";
        public string Status { get; set; } = "";
        public string Note { get; set; } = "";
    }
}
