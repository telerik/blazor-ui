    private void ToggleTask(TaskItem task)
    {
        task.IsCompleted = !task.IsCompleted;
    }

    private void OpenAddTaskModal()
    {
        newTaskName = "Review insurance authorization requests";
        newTaskPriority = "Low";
        newTaskDescription = "Review and evaluate incoming insurance authorization requests to ensure all information is accurate, complete, and compliant with relevant policies and guidelines before proceeding with approval or further action.";
        isAddTaskModalOpen = true;
    }

    private void CloseAddTaskModal()
    {
        isAddTaskModalOpen = false;
    }

    private void SetPriorityLow() => newTaskPriority = "Low";
    private void SetPriorityMedium() => newTaskPriority = "Medium";
    private void SetPriorityHigh() => newTaskPriority = "High";

    private void AddTask()
    {
        if (!string.IsNullOrWhiteSpace(newTaskName))
        {
            DailyTasks.Add(new TaskItem
            {
                Id = DailyTasks.Count + 1,
                Title = newTaskName,
                IsCompleted = false,
                Priority = newTaskPriority
            });
        }
        isAddTaskModalOpen = false;
    }

    public class ScheduleAppointment
    {
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string Room { get; set; } = "";
        public DateTime Start { get; set; }
        public DateTime End { get; set; }
        public bool IsAllDay { get; set; }
    }

    public class TaskItem
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public bool IsCompleted { get; set; }
        public string Priority { get; set; } = "Low";
    }
