@page "/schedule"
@rendermode InteractiveServer
@inject AppointmentService AppointmentService
@inject TaskService TaskService

<!-- ========== MAIN 2-COL ========== -->
<div class="hc-main">
    <!-- LEFT COLUMN — Scheduler -->
    <div class="hc-left">
        <div class="hc-card">
            <div class="hc-scheduler-wrapper" style="flex: 1;">
                <TelerikScheduler Data="@SchedulerAppointments"
                                  @bind-Date="@SelectedDate"
                                  @bind-View="@CurrentView"
                                  Height="600px"
                                  AllowCreate="true"
                                  AllowUpdate="false"
                                  AllowDelete="false"
                                  OnCreate="@OnSchedulerCreate"
                                  OnItemClick="@OnSchedulerItemClick"
                                  EnableWebMcpTools="true">
                    <SchedulerSettings>
                        <SchedulerWebMcpSettings Name="Appointments">
                            <SchedulerWebMcpTools>
                                <SchedulerWebMcpTool Command="@SchedulerWebMcpToolCommand.Create"
                                                     Description="Schedule a new patient appointment. Specify the title (patient name and reason), start date/time, and end date/time." />
                                <SchedulerWebMcpTool Command="@SchedulerWebMcpToolCommand.Navigate"
                                                     Description="Navigate the appointment calendar to a specific date to view that day's schedule." />
                                <SchedulerWebMcpTool Command="@SchedulerWebMcpToolCommand.ChangeView"
                                                     Description="Switch the schedule between Day, Week, Month, and Agenda views." />
                            </SchedulerWebMcpTools>
                        </SchedulerWebMcpSettings>
                    </SchedulerSettings>
                    <ItemTemplate>
                        @{
                            var apt = (Appointment)(object)context;
                        }
                        <div>
                            <div class="hc-event-title">@apt.Title</div>
                            <div class="hc-event-meta">@apt.Start.ToString("h:mm tt")–@apt.End.ToString("h:mm tt") · @apt.Room</div>
                        </div>
                    </ItemTemplate>
                    <SchedulerViews>
                        <SchedulerDayView StartTime="@DayStart" EndTime="@DayEnd" WorkDayStart="@DayStart" WorkDayEnd="@DayEnd" />
                        <SchedulerWeekView StartTime="@DayStart" EndTime="@DayEnd" WorkDayStart="@DayStart" WorkDayEnd="@DayEnd" />
                        <SchedulerMonthView />
                        <SchedulerAgendaView />
                    </SchedulerViews>
                </TelerikScheduler>
            </div>
            <div class="hc-scheduler-footer">
                <button class="hc-scheduler-footer-btn">
                    <svg viewBox="0 0 16 16" fill="none"><rect x="2" y="2" width="12" height="12" rx="2" stroke="#334155" stroke-width="1.2"/><line x1="2" y1="5.5" x2="14" y2="5.5" stroke="#334155" stroke-width="1.2"/><line x1="5.5" y1="2" x2="5.5" y2="5.5" stroke="#334155" stroke-width="1.2"/><line x1="10.5" y1="2" x2="10.5" y2="5.5" stroke="#334155" stroke-width="1.2"/></svg>
                    View Schedule
                </button>
            </div>
        </div>
    </div>

    <!-- RIGHT COLUMN — Daily Tasks -->
    <div class="hc-right">
        <div class="hc-right-card">
            <div class="hc-tasks-header">
                <div class="hc-tasks-header-title">Daily Tasks</div>
                <div class="hc-tasks-search">
                    <TelerikTextBox @bind-Value="@TaskSearch" Placeholder="Search tasks" Class="hc-tasks-search-input" />
                </div>
                <button class="hc-tasks-add-btn" title="Add task" @onclick="OpenAddTaskModal">
                    <svg viewBox="0 0 16 16" fill="none"><line x1="3.33" y1="8" x2="12.67" y2="8" stroke="white" stroke-width="1.33" stroke-linecap="round"/><line x1="8" y1="3.33" x2="8" y2="12.67" stroke="white" stroke-width="1.33" stroke-linecap="round"/></svg>
                    <span class="hc-tasks-add-btn-text">Add Task</span>
                </button>
            </div>

            <TelerikListView Data="@FilteredTasks" Class="hc-tasks-listview">
                <Template>
                    @{
                        var task = context;
                    }
                    <div class="hc-task-item" @onclick="() => OpenEditTaskModal(task)" style="cursor:pointer;">
                        <TelerikCheckBox @bind-Value="@task.IsCompleted" Class="hc-task-checkbox" EnableWebMcpTools="true" />
                        <span class="hc-task-text @(task.IsCompleted ? "completed" : "")">@task.Title</span>
                        <span class="hc-priority-badge hc-priority-@task.Priority.ToString().ToLowerInvariant()">@task.Priority</span>
                    </div>
                </Template>
            </TelerikListView>


        </div>
    </div>
</div>

<!-- ========== ADD/EDIT TASK MODAL ========== -->
<TelerikWindow @bind-Visible="@IsAddTaskModalOpen" Modal="true" Width="520px" Class="hc-modal">
    <WindowTitle>
        <strong>@TaskDialogTitle</strong>
    </WindowTitle>
    <WindowActions>
        <WindowAction Name="Close" />
    </WindowActions>
    <WindowContent>
        <div class="hc-modal-body">
            <div class="hc-modal-field">
                <label class="hc-modal-label">Task Name</label>
                <TelerikTextBox @bind-Value="@NewTaskName" Placeholder="Enter task name" Width="100%" />
            </div>
            <div class="hc-modal-field">
                <label class="hc-modal-label">Priority</label>
                <div class="hc-priority-seg">
                    <button class="hc-priority-seg-btn @(NewTaskPriority == TaskPriority.Low ? "active" : "")" @onclick="SetPriorityLow">Low</button>
                    <button class="hc-priority-seg-btn @(NewTaskPriority == TaskPriority.Medium ? "active" : "")" @onclick="SetPriorityMedium">Medium</button>
                    <button class="hc-priority-seg-btn @(NewTaskPriority == TaskPriority.High ? "active" : "")" @onclick="SetPriorityHigh">High</button>
                </div>
            </div>
            <div class="hc-modal-field">
                <label class="hc-modal-label">Description</label>
                <TelerikTextArea @bind-Value="@NewTaskDescription" Placeholder="Enter task description" Width="100%" Class="hc-modal-textarea" />
            </div>
            <div class="hc-modal-actions">
                <button class="hc-modal-btn hc-modal-btn-secondary" @onclick="CloseAddTaskModal">Discard</button>
                <button class="hc-modal-btn hc-modal-btn-primary" @onclick="SaveTask">@TaskSaveButtonText</button>
            </div>
        </div>
    </WindowContent>
</TelerikWindow>

<!-- ========== EVENT DETAIL DIALOG ========== -->
<TelerikWindow @bind-Visible="@IsEventDetailOpen" Modal="true" Width="420px" Class="hc-event-dialog">
    <WindowTitle>
        @if (SelectedAppointment != null)
        {
            <span>@SelectedAppointment.Description - @SelectedAppointment.PatientName</span>
        }
    </WindowTitle>
    <WindowActions>
        <WindowAction Name="Close" />
    </WindowActions>
    <WindowContent>
        @if (SelectedAppointment != null)
        {
            <div class="hc-evt-content">
                <p class="hc-evt-section-label">Appointment time</p>

                <div class="hc-evt-detail-row">
                    <TelerikSvgIcon Icon="@SvgIcon.Calendar" />
                    <span>@FormatDialogDate(SelectedAppointment.Start)</span>
                </div>

                <div class="hc-evt-detail-row">
                    <TelerikSvgIcon Icon="@SvgIcon.Clock" />
                    <span>@FormatDialogTime(SelectedAppointment.Start, SelectedAppointment.End)</span>
                </div>

                <div class="hc-evt-detail-row">
                    <TelerikSvgIcon Icon="@SvgIcon.MapMarkerTarget" />
                    <span>@SelectedAppointment.Room</span>
                </div>

                <div class="hc-evt-detail-row">
                    <TelerikSvgIcon Icon="@SvgIcon.User" />
                    <span>In-person visit</span>
                </div>
            </div>

            <div class="hc-evt-actions">
                <button class="hc-evt-close-btn" @onclick="() => IsEventDetailOpen = false">Close</button>
            </div>
        }
    </WindowContent>
</TelerikWindow>

@code {
    #region Fields

    private DateTime SelectedDate { get; set; } = new DateTime(2026, 3, 10);
    private SchedulerView CurrentView { get; set; } = SchedulerView.Day;
    private DateTime DayStart { get; set; } = new DateTime(2000, 1, 1, 7, 0, 0);
    private DateTime DayEnd { get; set; } = new DateTime(2000, 1, 1, 17, 0, 0);

    private List<Appointment> SchedulerAppointments { get; set; } = new();
    private List<TaskItem> DailyTasks { get; set; } = new();
    private string TaskSearch { get; set; } = "";

    private List<TaskItem> FilteredTasks => string.IsNullOrWhiteSpace(TaskSearch)
        ? DailyTasks
        : DailyTasks.Where(t => t.Title.Contains(TaskSearch, StringComparison.OrdinalIgnoreCase)).ToList();

    private bool IsAddTaskModalOpen { get; set; }
    private string NewTaskName { get; set; } = "";
    private TaskPriority NewTaskPriority { get; set; } = TaskPriority.Medium;
    private string NewTaskDescription { get; set; } = "";
    private TaskItem? EditingTask { get; set; }

    private string TaskDialogTitle => EditingTask != null ? "Edit Task" : "Add Task";
    private string TaskSaveButtonText => EditingTask != null ? "Save changes" : "Add task";

    // Event detail dialog
    private bool IsEventDetailOpen { get; set; }
    private Appointment? SelectedAppointment { get; set; }

    #endregion

    #region Lifecycle

    protected override void OnInitialized()
    {
        SchedulerAppointments = AppointmentService.GetSchedulerAppointments();
        DailyTasks            = TaskService.GetDailyTasks();
    }

    #endregion

    #region Task Methods

    private void OpenAddTaskModal()
    {
        EditingTask        = null;
        NewTaskName        = "";
        NewTaskPriority    = TaskPriority.Medium;
        NewTaskDescription = "";
        IsAddTaskModalOpen = true;
    }

    private void OpenEditTaskModal(TaskItem task)
    {
        EditingTask        = task;
        NewTaskName        = task.Title;
        NewTaskPriority    = task.Priority;
        NewTaskDescription = "";
        IsAddTaskModalOpen = true;
    }

    private void CloseAddTaskModal()
    {
        IsAddTaskModalOpen = false;
        EditingTask        = null;
        NewTaskName        = "";
        NewTaskPriority    = TaskPriority.Medium;
        NewTaskDescription = "";
    }

    private void SetPriorityLow()    => NewTaskPriority = TaskPriority.Low;
    private void SetPriorityMedium() => NewTaskPriority = TaskPriority.Medium;
    private void SetPriorityHigh()   => NewTaskPriority = TaskPriority.High;

    private void SaveTask()
    {
        if (string.IsNullOrWhiteSpace(NewTaskName))
            return;

        if (EditingTask != null)
        {
            EditingTask.Title    = NewTaskName;
            EditingTask.Priority = NewTaskPriority;
        }
        else
        {
            var newTask = new TaskItem
            {
                Id          = DailyTasks.Count > 0 ? DailyTasks.Max(t => t.Id) + 1 : 1,
                Title       = NewTaskName,
                IsCompleted = false,
                Priority    = NewTaskPriority,
            };
            DailyTasks = new List<TaskItem> { newTask }.Concat(DailyTasks).ToList();
        }

        CloseAddTaskModal();
    }

    #endregion

    #region Scheduler Create

    private void OnSchedulerCreate(SchedulerCreateEventArgs args)
    {
        var appointment = (Appointment)args.Item;
        appointment.Id = SchedulerAppointments.Count > 0 ? SchedulerAppointments.Max(a => a.Id) + 1 : 1;
        SchedulerAppointments.Add(appointment);
    }

    #endregion

    #region Event Detail Dialog

    private void OnSchedulerItemClick(SchedulerItemClickEventArgs args)
    {
        SelectedAppointment = args.Item as Appointment;
        if (SelectedAppointment != null)
        {
            IsEventDetailOpen = true;
        }
    }

    private string FormatDialogDate(DateTime date)
    {
        return date.ToString("ddd, MMMM d, yyyy");
    }

    private string FormatDialogTime(DateTime start, DateTime end)
    {
        return $"{start:h:mm tt} - {end:h:mm tt}";
    }

    #endregion
}