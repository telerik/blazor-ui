@page "/clinical-analytics"
@rendermode InteractiveServer

<style>
    /* ========== HEADING / TOOLBAR ========== */
    .hc-ca-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        position: relative;
        z-index: 10;
        gap: 24px;
    }

    .hc-ca-heading {
        display: flex;
        flex-direction: column;
        gap: 8px;
        flex: 1;
        min-width: 0;
    }

    .hc-ca-heading h1 {
        font-weight: 600;
        font-size: 42px;
        line-height: 120%;
        color: #232A36;
        margin: 0;
    }

    .hc-ca-heading p {
        font-weight: 400;
        font-size: 16px;
        line-height: 150%;
        color: #4A5666;
        margin: 0;
    }

    .hc-ca-controls {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-shrink: 0;
    }

    /* DropDown pill style */
    .hc-ca-controls .k-dropdownlist {
        border-radius: 9999px;
        border: 1px solid rgba(23, 56, 99, 0.08);
        font-family: 'Poppins', sans-serif;
        font-size: 16px;
        min-width: 249px;
    }

    .hc-ca-controls .k-dropdownlist .k-input-inner {
        font-family: 'Poppins', sans-serif;
    }

    /* DropDown popup border-radius to match the pill input */
    .hc-ca-dropdown-popup.k-animation-container .k-list-container,
    .hc-ca-dropdown-popup .k-list-container {
        border-radius: 16px;
    }

    /* Export button pill */
    .hc-ca-export-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 4px;
        padding: 4px 12px;
        background: #F3F5F7;
        border: 1px solid rgba(23, 56, 99, 0.08);
        border-radius: 9999px;
        font-family: 'Poppins', sans-serif;
        font-size: 16px;
        font-weight: 400;
        color: #232A36;
        cursor: pointer;
        white-space: nowrap;
        height: 34px;
    }

    .hc-ca-export-btn:hover {
        background: #E8EAED;
    }

    .hc-ca-export-btn .k-svg-icon,
    .hc-ca-export-btn svg {
        width: 16px;
        height: 16px;
    }

    /* ========== CHARTS CONTAINER ========== */
    .hc-ca-charts {
        display: flex;
        flex-direction: column;
        gap: 32px;
        width: 100%;
        position: relative;
        z-index: 10;
    }

    /* ========== CARD ========== */
    .hc-ca-card {
        background: #FFFFFF;
        border: 1px solid rgba(255, 255, 255, 0.0001);
        box-shadow: 0px 1px 3px rgba(0, 0, 0, 0.04), 0px 2px 6px -1px rgba(0, 0, 0, 0.06);
        border-radius: 16px;
        position: relative;
        z-index: 10;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .hc-ca-card-header {
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .hc-ca-card-title {
        font-weight: 700;
        font-size: 16px;
        line-height: 150%;
        color: #232A36;
        margin: 0;
    }

    .hc-ca-card-subtitle {
        font-weight: 400;
        font-size: 14px;
        line-height: 142%;
        color: #4A5666;
        margin: 0;
    }

    .hc-ca-card-body {
        padding: 10px 20px 20px;
    }

    .hc-ca-chart-area {
        background: linear-gradient(179.48deg, rgba(255, 255, 255, 0) 0.02%, rgba(255, 255, 255, 0.2) 49.56%, rgba(255, 255, 255, 0.4) 74.34%);
        border-radius: 12px;
        padding: 16px;
    }

    /* ========== BOTTOM ROW ========== */
    .hc-ca-bottom-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 32px;
        width: 100%;
    }

    /* ========== GAUGE CARD ========== */
    .hc-ca-gauge-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
        padding: 0 20px 20px;
        flex: 1;
        justify-content: flex-end;
    }

    .hc-ca-gauge-label-text {
        font-family: 'Poppins', sans-serif;
        font-weight: 400;
        font-size: 16px;
        line-height: 150%;
        color: #3D3D3D;
        text-align: center;
    }

    .hc-ca-gauge-legend {
        display: flex;
        flex-direction: column;
        gap: 8px;
        width: 100%;
    }

    .hc-ca-gauge-legend-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 8px;
    }

    .hc-ca-gauge-legend-left {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .hc-ca-legend-dot {
        width: 15px;
        height: 15px;
        border-radius: 9999px;
        flex-shrink: 0;
    }

    .hc-ca-legend-label {
        font-family: 'Poppins', sans-serif;
        font-weight: 400;
        font-size: 14px;
        line-height: 142%;
        color: #232A36;
    }

    .hc-ca-legend-range {
        font-family: 'Poppins', sans-serif;
        font-weight: 400;
        font-size: 14px;
        line-height: 142%;
        color: #232A36;
    }

    /* ========== DONUT CENTER ALIGN ========== */
    .hc-ca-donut-body {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 10px 20px 20px;
    }

    /* Donut custom legend */
    .hc-ca-donut-legend {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 16px;
        padding-top: 8px;
    }
    .hc-ca-donut-legend-item {
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .hc-ca-donut-legend-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        flex-shrink: 0;
    }
    .hc-ca-donut-legend-text {
        font-family: 'Poppins', sans-serif;
        font-size: 12px;
        color: #4A5666;
    }

    /* ========== CHART OVERRIDES ========== */
    .hc-ca-card .k-chart {
        font-family: 'Poppins', sans-serif;
    }

    /* ========== RESPONSIVE ========== */
    @@media (max-width: 1440px) {
        .hc-ca-heading h1 {
            font-size: 36px;
        }
    }

    @@media (max-width: 1200px) {
        .hc-ca-toolbar {
            flex-wrap: wrap;
        }

        .hc-ca-heading h1 {
            font-size: 32px;
        }

        .hc-ca-card-body {
            padding: 10px 16px 16px;
        }
    }

    @@media (max-width: 960px) {
        .hc-ca-bottom-row {
            grid-template-columns: 1fr;
        }

        .hc-ca-heading h1 {
            font-size: 28px;
        }

        .hc-ca-controls {
            flex-wrap: wrap;
        }
    }

    @@media (max-width: 640px) {
        .hc-ca-heading h1 {
            font-size: 24px;
        }

        .hc-ca-heading p {
            font-size: 14px;
        }

        .hc-ca-card-header {
            padding: 16px;
        }

        .hc-ca-card-body {
            padding: 8px 12px 12px;
        }

        .hc-ca-bottom-row {
            gap: 20px;
        }

        .hc-ca-charts {
            gap: 20px;
        }
    }
</style>

<!-- ========== TOOLBAR ========== -->
<div class="hc-ca-toolbar">
    <div class="hc-ca-heading">
        <h1>Clinical Analytics</h1>
        <p>Patient trends, vitals, lab results, and risk assessment overview</p>
    </div>
    <div class="hc-ca-controls">
        <TelerikDropDownList Data="@Patients"
                             @bind-Value="@SelectedPatientId"
                             TextField="DisplayText"
                             ValueField="Id"
                             Width="249px">
            <DropDownListSettings>
                <DropDownListPopupSettings Class="hc-ca-dropdown-popup" />
            </DropDownListSettings>
        </TelerikDropDownList>
        <button class="hc-ca-export-btn" @onclick="OnExportClick">
            <TelerikSvgIcon Icon="@SvgIcon.Download" />
            <span>Export</span>
        </button>
    </div>
</div>

<!-- ========== CHARTS ========== -->
<div class="hc-ca-charts">

    <!-- ===== VITALS OVER TIME (Line Chart) ===== -->
    <div class="hc-ca-card">
        <div class="hc-ca-card-header">
            <h2 class="hc-ca-card-title">Vitals Over Time</h2>
            <p class="hc-ca-card-subtitle">Multi-series tracking of blood pressure, heart rate, SpO2, and temperature</p>
        </div>
        <div class="hc-ca-card-body">
            <div class="hc-ca-chart-area">
                <TelerikChart Height="340px">
                    <ChartSeriesItems>
                        <ChartSeries Type="ChartSeriesType.Line"
                                     Name="Systolic BP"
                                     Data="@VitalsData"
                                     Field="SystolicBP"
                                     CategoryField="Month"
                                     Color="#FF6358"
                                     Style="ChartSeriesStyle.Smooth">
                            <ChartSeriesMarkers Visible="true" Size="10" Background="#FFFFFF">
                                <ChartSeriesMarkersBorder Color="#FF6358" Width="2" />
                            </ChartSeriesMarkers>
                        </ChartSeries>
                        <ChartSeries Type="ChartSeriesType.Line"
                                     Name="Diastolic BP"
                                     Data="@VitalsData"
                                     Field="DiastolicBP"
                                     CategoryField="Month"
                                     Color="#FFE162"
                                     Style="ChartSeriesStyle.Smooth">
                            <ChartSeriesMarkers Visible="true" Size="10" Background="#FFFFFF">
                                <ChartSeriesMarkersBorder Color="#FFE162" Width="2" />
                            </ChartSeriesMarkers>
                        </ChartSeries>
                        <ChartSeries Type="ChartSeriesType.Line"
                                     Name="Heart Rate"
                                     Data="@VitalsData"
                                     Field="HeartRate"
                                     CategoryField="Month"
                                     Color="#4CD180"
                                     Style="ChartSeriesStyle.Smooth">
                            <ChartSeriesMarkers Visible="true" Size="10" Background="#FFFFFF">
                                <ChartSeriesMarkersBorder Color="#4CD180" Width="2" />
                            </ChartSeriesMarkers>
                        </ChartSeries>
                        <ChartSeries Type="ChartSeriesType.Line"
                                     Name="SpO2 (%)"
                                     Data="@VitalsData"
                                     Field="SpO2"
                                     CategoryField="Month"
                                     Color="#4B5FFA"
                                     Style="ChartSeriesStyle.Smooth">
                            <ChartSeriesMarkers Visible="true" Size="10" Background="#FFFFFF">
                                <ChartSeriesMarkersBorder Color="#4B5FFA" Width="2" />
                            </ChartSeriesMarkers>
                        </ChartSeries>
                        <ChartSeries Type="ChartSeriesType.Line"
                                     Name="Temperature"
                                     Data="@VitalsData"
                                     Field="Temperature"
                                     CategoryField="Month"
                                     Color="#AC58FF"
                                     Style="ChartSeriesStyle.Smooth">
                            <ChartSeriesMarkers Visible="true" Size="10" Background="#FFFFFF">
                                <ChartSeriesMarkersBorder Color="#AC58FF" Width="2" />
                            </ChartSeriesMarkers>
                        </ChartSeries>
                        <ChartSeries Type="ChartSeriesType.Line"
                                     Name="Pulse"
                                     Data="@VitalsData"
                                     Field="Pulse"
                                     CategoryField="Month"
                                     Color="#FF5892"
                                     Style="ChartSeriesStyle.Smooth">
                            <ChartSeriesMarkers Visible="true" Size="10" Background="#FFFFFF">
                                <ChartSeriesMarkersBorder Color="#FF5892" Width="2" />
                            </ChartSeriesMarkers>
                        </ChartSeries>
                    </ChartSeriesItems>
                    <ChartCategoryAxes>
                        <ChartCategoryAxis>
                            <ChartCategoryAxisLabels>
                                <ChartCategoryAxisLabelsRotation Angle="-90" />
                            </ChartCategoryAxisLabels>
                            <ChartCategoryAxisMajorGridLines Visible="false" />
                        </ChartCategoryAxis>
                    </ChartCategoryAxes>
                    <ChartValueAxes>
                        <ChartValueAxis Min="0" Max="35">
                            <ChartValueAxisLabels />
                            <ChartValueAxisMajorGridLines Color="rgba(23,56,99,0.08)" />
                        </ChartValueAxis>
                    </ChartValueAxes>
                    <ChartLegend Position="ChartLegendPosition.Bottom">
                        <ChartLegendLabels />
                    </ChartLegend>
                    <ChartTooltip Visible="true" />
                </TelerikChart>
            </div>
        </div>
    </div>

    <!-- ===== ALERTS OVER TIME (Stacked Column Chart) ===== -->
    <div class="hc-ca-card">
        <div class="hc-ca-card-header">
            <h2 class="hc-ca-card-title">Alerts Over Time</h2>
            <p class="hc-ca-card-subtitle">Alert count trendy by severity level</p>
        </div>
        <div class="hc-ca-card-body">
            <div class="hc-ca-chart-area">
                <TelerikChart Height="340px">
                    <ChartSeriesItems>
                        <ChartSeries Type="ChartSeriesType.Column"
                                     Name="Critical"
                                     Data="@AlertsOverTimeData"
                                     Field="Critical"
                                     CategoryField="Month"
                                     Color="#FF6358">
                            <ChartSeriesStack Enabled="true" Group="alerts" />
                        </ChartSeries>
                        <ChartSeries Type="ChartSeriesType.Column"
                                     Name="Warning"
                                     Data="@AlertsOverTimeData"
                                     Field="Warning"
                                     CategoryField="Month"
                                     Color="#FFE162">
                            <ChartSeriesStack Enabled="true" Group="alerts" />
                        </ChartSeries>
                        <ChartSeries Type="ChartSeriesType.Column"
                                     Name="Info"
                                     Data="@AlertsOverTimeData"
                                     Field="Info"
                                     CategoryField="Month"
                                     Color="#4B5FFA">
                            <ChartSeriesStack Enabled="true" Group="alerts" />
                        </ChartSeries>
                    </ChartSeriesItems>
                    <ChartCategoryAxes>
                        <ChartCategoryAxis>
                            <ChartCategoryAxisLabels>
                                <ChartCategoryAxisLabelsRotation Angle="-90" />
                            </ChartCategoryAxisLabels>
                            <ChartCategoryAxisMajorGridLines Visible="false" />
                        </ChartCategoryAxis>
                    </ChartCategoryAxes>
                    <ChartValueAxes>
                        <ChartValueAxis Min="0" Max="35">
                            <ChartValueAxisLabels />
                            <ChartValueAxisMajorGridLines Color="rgba(23,56,99,0.08)" />
                        </ChartValueAxis>
                    </ChartValueAxes>
                    <ChartLegend Position="ChartLegendPosition.Bottom">
                        <ChartLegendLabels />
                    </ChartLegend>
                    <ChartTooltip Visible="true" />
                </TelerikChart>
            </div>
        </div>
    </div>

    <!-- ===== PATIENT HEALTH METRICS OVER TIME (Area Chart) ===== -->
    <div class="hc-ca-card">
        <div class="hc-ca-card-header">
            <h2 class="hc-ca-card-title">Patient Health Metrics Over Time</h2>
            <p class="hc-ca-card-subtitle">Long-term tracking of key lab results and health indicators</p>
        </div>
        <div class="hc-ca-card-body">
            <div class="hc-ca-chart-area">
                <TelerikChart Height="400px">
                    <ChartSeriesItems>
                        <ChartSeries Type="ChartSeriesType.Area"
                                     Data="@HealthMetricsData"
                                     Field="Glucose"
                                     CategoryField="Month"
                                     Name="Glucose (mg/dL)"
                                     Color="#4477FF"
                                     Style="@ChartSeriesStyle.Smooth"
                                     Opacity="0.15">
                            <ChartSeriesLine Color="#4477FF" Width="2" Style="@ChartSeriesLineStyle.Smooth" />
                        </ChartSeries>
                        <ChartSeries Type="ChartSeriesType.Area"
                                     Data="@HealthMetricsData"
                                     Field="Cholesterol"
                                     CategoryField="Month"
                                     Name="Cholesterol (mg/dL)"
                                     Color="#7B5CFA"
                                     Style="@ChartSeriesStyle.Smooth"
                                     Opacity="0.15">
                            <ChartSeriesLine Color="#7B5CFA" Width="2" Style="@ChartSeriesLineStyle.Smooth" />
                        </ChartSeries>
                        <ChartSeries Type="ChartSeriesType.Area"
                                     Data="@HealthMetricsData"
                                     Field="Hemoglobin"
                                     CategoryField="Month"
                                     Name="Hemoglobin (g/dL)"
                                     Color="#00B87A"
                                     Style="@ChartSeriesStyle.Smooth"
                                     Opacity="0.15">
                            <ChartSeriesLine Color="#00B87A" Width="2" Style="@ChartSeriesLineStyle.Smooth" />
                        </ChartSeries>
                        <ChartSeries Type="ChartSeriesType.Area"
                                     Data="@HealthMetricsData"
                                     Field="Creatinine"
                                     CategoryField="Month"
                                     Name="Creatinine (mg/dL)"
                                     Color="#FF9F43"
                                     Style="@ChartSeriesStyle.Smooth"
                                     Opacity="0.15">
                            <ChartSeriesLine Color="#FF9F43" Width="2" Style="@ChartSeriesLineStyle.Smooth" />
                        </ChartSeries>
                        <ChartSeries Type="ChartSeriesType.Area"
                                     Data="@HealthMetricsData"
                                     Field="Bilirubin"
                                     CategoryField="Month"
                                     Name="Bilirubin (mg/dL)"
                                     Color="#FF4757"
                                     Style="@ChartSeriesStyle.Smooth"
                                     Opacity="0.15">
                            <ChartSeriesLine Color="#FF4757" Width="2" Style="@ChartSeriesLineStyle.Smooth" />
                        </ChartSeries>
                    </ChartSeriesItems>
                    <ChartCategoryAxes>
                        <ChartCategoryAxis>
                            <ChartCategoryAxisLabels Font="12px Poppins, sans-serif" Color="#94A3B8" />
                            <ChartCategoryAxisMajorGridLines Visible="false" />
                            <ChartCategoryAxisLine Visible="false" />
                        </ChartCategoryAxis>
                    </ChartCategoryAxes>
                    <ChartValueAxes>
                        <ChartValueAxis Min="0" Max="220" MajorUnit="55">
                            <ChartValueAxisLabels Font="12px Poppins, sans-serif" Color="#94A3B8" />
                            <ChartValueAxisMajorGridLines Color="#F0F0F0" DashType="@DashType.Dot" />
                            <ChartValueAxisLine Visible="false" />
                        </ChartValueAxis>
                    </ChartValueAxes>
                    <ChartLegend Position="ChartLegendPosition.Bottom">
                        <ChartLegendLabels Font="13px Poppins, sans-serif" Color="#4A5666" />
                    </ChartLegend>
                    <ChartTooltip Visible="true" Shared="true" />
                </TelerikChart>
            </div>
        </div>
    </div>

    <!-- ===== BOTTOM ROW: DONUT + GAUGE ===== -->
    <div class="hc-ca-bottom-row">

        <!-- ALERTS BY CATEGORY (Donut Chart) -->
        <div class="hc-ca-card">
            <div class="hc-ca-card-header">
                <h2 class="hc-ca-card-title">Alerts by Category</h2>
                <p class="hc-ca-card-subtitle">Distribution of alerts by clinical category</p>
            </div>
            <div class="hc-ca-donut-body">
                <TelerikChart Height="370px" Width="100%">
                    <ChartSeriesItems>
                        <ChartSeries Type="ChartSeriesType.Donut"
                                     Data="@AlertsByCategoryData"
                                     Field="Value"
                                     CategoryField="Category"
                                     ColorField="Color"
                                     HoleSize="85"
                                     Size="65"
                                     StartAngle="90">
                            <ChartSeriesLabels Visible="true"
                                               Position="ChartSeriesLabelsPosition.OutsideEnd"
                                               Template="#=category#"
                                               Background="transparent"
                                               Color="#232A36"
                                               Font="13px Poppins, sans-serif"
                                               Distance="20" />
                        </ChartSeries>
                    </ChartSeriesItems>
                    <ChartLegend Visible="false" />
                    <ChartTooltip Visible="true" />
                </TelerikChart>
                <div class="hc-ca-donut-legend">
                    @for (int i = 0; i < AlertsByCategoryData.Count; i++)
                    {
                        var item = AlertsByCategoryData[i];
                        <div class="hc-ca-donut-legend-item">
                            <span class="hc-ca-donut-legend-dot" style="background: @item.Color;"></span>
                            <span class="hc-ca-donut-legend-text">@i:@((int)item.Value)</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- RISK SCORE (Arc Gauge) -->
        <div class="hc-ca-card">
            <div class="hc-ca-card-header">
                <h2 class="hc-ca-card-title">Risk Score</h2>
                <p class="hc-ca-card-subtitle">Patient health risk assessment</p>
            </div>
            <div class="hc-ca-gauge-wrapper">
                <TelerikArcGauge Width="302px" Height="160px">
                    <ArcGaugeScales>
                        <ArcGaugeScale Min="0" Max="100" StartAngle="0" EndAngle="180">
                            <ArcGaugeScaleLabels Visible="false" />
                        </ArcGaugeScale>
                    </ArcGaugeScales>
                    <ArcGaugePointers>
                        <ArcGaugePointer Value="@RiskScoreValue" Size="14" Color="#BFA94A" />
                    </ArcGaugePointers>
                    <ArcGaugeCenterLabel>
                        <Template>
                            <div style="font-family: Poppins, sans-serif; font-weight: 700; font-size: 32px; color: #BFA94A; text-align: center; line-height: 1.2;">
                                @(RiskScoreValue)%
                            </div>
                        </Template>
                    </ArcGaugeCenterLabel>
                </TelerikArcGauge>

                <div class="hc-ca-gauge-label-text">Out of 100</div>

                <div class="hc-ca-gauge-legend">
                    <div class="hc-ca-gauge-legend-row">
                        <div class="hc-ca-gauge-legend-left">
                            <div class="hc-ca-legend-dot" style="background: #FF6358;"></div>
                            <span class="hc-ca-legend-label">High Risk</span>
                        </div>
                        <span class="hc-ca-legend-range">0-39</span>
                    </div>
                    <div class="hc-ca-gauge-legend-row">
                        <div class="hc-ca-gauge-legend-left">
                            <div class="hc-ca-legend-dot" style="background: #BFA94A;"></div>
                            <span class="hc-ca-legend-label">Medium Risk</span>
                        </div>
                        <span class="hc-ca-legend-range">40-69</span>
                    </div>
                    <div class="hc-ca-gauge-legend-row">
                        <div class="hc-ca-gauge-legend-left">
                            <div class="hc-ca-legend-dot" style="background: #4CD180;"></div>
                            <span class="hc-ca-legend-label">Low Risk</span>
                        </div>
                        <span class="hc-ca-legend-range">70-100</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    /* ========== PATIENT SELECTION ========== */
    private int SelectedPatientId { get; set; } = 1;

    private List<PatientOption> Patients { get; set; } = new()
    {
        new() { Id = 1, DisplayText = "James Wilson (P-104582)" },
        new() { Id = 2, DisplayText = "Sophia Martinez (P-203847)" },
        new() { Id = 3, DisplayText = "Michael O'Connor (P-301928)" },
        new() { Id = 4, DisplayText = "Ava Patel (P-409283)" },
    };

    /* ========== RISK SCORE ========== */
    private int RiskScoreValue { get; set; } = 50;

    /* ========== VITALS DATA ========== */
