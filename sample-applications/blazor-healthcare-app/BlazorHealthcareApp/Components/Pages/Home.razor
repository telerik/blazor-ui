            </div>
            <div class="hc-modal-actions">
                <button class="hc-modal-btn hc-modal-btn-secondary" @onclick="() => isMessageModalOpen = false">Discard</button>
                <button class="hc-modal-btn hc-modal-btn-primary" @onclick="() => isMessageModalOpen = false">Send message</button>
