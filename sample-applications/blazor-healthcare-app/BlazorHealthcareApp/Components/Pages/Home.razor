@page "/"
@rendermode InteractiveServer

<style>
    /* ========== HEADING ========== */
    .hc-heading { display: flex; flex-direction: column; gap: 8px; width: 100%; position: relative; z-index: 1; }
    .hc-heading h1 {
        font-weight: 600; font-size: 42px; line-height: 120%;
        color: #232A36; margin: 0;
    }
    .hc-heading p {
        font-weight: 400; font-size: 16px; line-height: 150%;
        color: #4A5666; margin: 0;
    }

    /* ========== MAIN 2-COL ========== */
    .hc-main {
        display: flex;
        gap: 32px;
        width: 100%;
        flex: 1;
        position: relative;
        z-index: 1;
    }
    .hc-left { display: flex; flex-direction: column; gap: 32px; flex: 1 1 62%; min-width: 0; }
    .hc-right { display: flex; flex-direction: column; width: 36%; min-width: min(340px, 100%); }

    /* ========== CARDS ========== */
    .hc-card {
        background: #FFFFFF;
        box-shadow: 0px 1px 3px rgba(0, 0, 0, 0.04), 0px 2px 6px -1px rgba(0, 0, 0, 0.06);
        border-radius: 16px;
        padding: 24px;
        position: relative;
        z-index: 1;
    }

    .hc-card-title {
        font-weight: 700; font-size: 24px; line-height: 150%;
        color: #232A36; margin: 0 0 20px 0;
    }

    /* ========== QUICK ACTIONS ========== */
    .hc-quick-actions { display: flex; gap: 22px; }

    .hc-qa-card {
        flex: 1;
        background: #F1F5F9;
        border: 1px solid rgba(23, 56, 99, 0.08);
        border-radius: 12px;
        display: flex;
        flex-direction: column;
        position: relative;
        overflow: hidden;
        transition: background 0.3s ease-in-out, box-shadow 0.3s ease-in-out, border-color 0.3s ease-in-out;
    }
    .hc-qa-card:hover {
        border-color: rgba(99, 102, 251, 0.15);
        box-shadow: 0px 8px 20px rgba(0, 100, 200, 0.1);
    }
    .hc-qa-header { padding: 12px; display: flex; flex-direction: column; gap: 4px; }
    .hc-qa-title { font-weight: 700; font-size: 16px; line-height: 150%; color: #232A36; margin: 0; }
    .hc-qa-subtitle { font-weight: 400; font-size: 14px; line-height: 142%; color: #4A5666; margin: 0; }

    .hc-qa-footer { padding: 12px; display: flex; align-items: center; }

    .hc-qa-plus {
        height: 42px; min-width: 42px; max-width: 42px;
        background: #334155; border: 1px solid #334155;
        border-radius: 9999px;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; color: #FFFFFF;
        gap: 0;
        padding: 0;
        overflow: hidden;
        white-space: nowrap;
        transition: max-width 0.3s ease-in-out, padding 0.3s ease-in-out, gap 0.3s ease-in-out;
    }
    .hc-qa-plus:hover { background: #1e293b; }
    .hc-qa-plus svg { width: 16px; height: 16px; flex-shrink: 0; }

    .hc-qa-btn-text {
        font-family: 'Poppins', sans-serif;
        font-size: 14px; font-weight: 500;
        color: #FFFFFF;
        opacity: 0;
        max-width: 0;
        overflow: hidden;
        transition: opacity 0.25s ease-in-out 0.05s, max-width 0.3s ease-in-out;
    }

    .hc-qa-card:hover .hc-qa-plus {
        max-width: 200px;
        padding: 0 16px 0 12px;
        gap: 6px;
    }
    .hc-qa-card:hover .hc-qa-btn-text {
        opacity: 1;
        max-width: 120px;
    }

    .hc-qa-icon {
        position: absolute; right: 12px; top: 12px;
        width: 42px; height: 42px;
        opacity: 0.4;
        display: flex; align-items: center; justify-content: center;
        color: #6366FB;
        transition: opacity 0.3s ease-in-out, filter 0.3s ease-in-out;
    }
    .hc-qa-card:hover .hc-qa-icon {
        opacity: 0.7;
        filter: saturate(1.6) brightness(1.05);
    }
    .hc-qa-icon svg { width: 42px; height: 42px; }
    .hc-qa-icon .k-svg-icon { width: 42px; height: 42px; }

    /* ========== APPOINTMENTS ========== */
    .hc-appt-header {
        display: flex; justify-content: space-between; align-items: center;
        margin-bottom: 20px;
    }
    .hc-appt-header .hc-card-title { margin: 0; }

    .hc-view-schedule-btn {
        display: flex; align-items: center; gap: 4px;
        padding: 8px 16px;
        background: #334155; border: 1px solid #334155;
        border-radius: 9999px;
        color: #FFFFFF;
        font-family: 'Poppins', sans-serif;
        font-size: 16px; font-weight: 400; line-height: 150%;
        cursor: pointer; text-decoration: none; white-space: nowrap;
    }
    .hc-view-schedule-btn:hover { background: #1e293b; color: #FFFFFF; text-decoration: none; }
    .hc-view-schedule-btn svg { width: 16px; height: 16px; }

    /* Grid overrides */
    .hc-grid-wrapper .k-grid { border-radius: 8px; border: 1px solid rgba(23, 56, 99, 0.08); font-family: 'Poppins', sans-serif; }
    .hc-grid-wrapper .k-grid table { table-layout: fixed; }
    .hc-grid-wrapper .k-grid .k-grid-header .k-header {
        background: #F9FAFB !important;
        border-bottom: 1px solid rgba(23, 56, 99, 0.08);
        font-weight: 500; font-size: 14px; color: #232A36;
        padding: 8px 12px;
        text-align: left;
    }
    .hc-grid-wrapper .k-grid td {
        padding: 8px 12px !important;
        font-size: 14px; color: #232A36;
        border-bottom: none !important;
        vertical-align: middle;
        text-align: left;
    }
    .hc-grid-wrapper .k-grid .k-master-row { height: 42px; }
    .hc-grid-wrapper .k-grid .k-master-row:nth-child(even) td {
        background: rgba(56, 66, 80, 0.05);
    }
    .hc-grid-wrapper .k-grid .k-master-row:nth-child(odd) td {
        background: #FFFFFF;
    }
    .hc-grid-wrapper .k-grid .k-grid-content { overflow-y: auto; max-height: 440px; }
    .hc-grid-wrapper .k-grid .k-grid-header { padding-right: 0 !important; }
    .hc-grid-wrapper .k-grid .k-pager { display: none !important; }

    /* Status badges */
    .hc-badge {
        display: inline-flex; align-items: center; justify-content: center;
        padding: 6px 10px;
        border-radius: 9999px;
        font-size: 12px; line-height: 133%;
        white-space: nowrap;
    }
    .hc-badge-complete { background: #EAEFF5; border: 1px solid #CBD5E1; color: #000214; }
    .hc-badge-inprogress { background: #EBECFF; border: 1px solid #D4D6FF; color: #383BA8; }
    .hc-badge-upcoming { background: #FDF6FF; border: 1px solid #DDB5FB; color: #37164B; }
    .hc-badge-cancelled { background: #D2E2FB; border: 1px solid #6098F2; color: #002259; }

    /* ========== RIGHT COL ========== */
    .hc-right-card {
        background: #FFFFFF;
        box-shadow: 0px 1px 3px rgba(0, 0, 0, 0.04), 0px 2px 6px -1px rgba(0, 0, 0, 0.06);
        border-radius: 16px;
        display: flex;
        flex-direction: column;
        height: 100%;
        position: relative;
        z-index: 1;
    }

    .hc-right-section-header {
        padding: 24px 24px 12px;
        font-weight: 700; font-size: 24px; line-height: 150%;
        color: #232A36;
    }

    /* Next patient */
    .hc-next-patient { padding: 12px 24px 24px; display: flex; flex-direction: column; gap: 20px; }

    .hc-patient-row {
        display: flex; justify-content: space-between; align-items: center;
    }

    .hc-patient-info { display: flex; align-items: center; gap: 12px; }

    .hc-patient-avatar {
        width: 72px; height: 72px; border-radius: 50%;
        background: linear-gradient(135deg, #667eea, #764ba2);
        display: flex; align-items: center; justify-content: center;
        color: #fff; font-weight: 600; font-size: 24px;
        overflow: hidden; flex-shrink: 0;
    }

    .hc-patient-name-block { display: flex; flex-direction: column; }
    .hc-patient-name-row { display: flex; align-items: center; gap: 4px; }
    .hc-patient-name {
        font-weight: 400; font-size: 20px; line-height: 150%;
        color: #232A36;
    }

    .hc-view-profile-btn {
        display: inline-flex; align-items: center; gap: 4px;
        background: none; border: none; cursor: pointer;
        font-family: 'Poppins', sans-serif;
        font-size: 14px; color: #4A5666; padding: 4px 8px;
        border-radius: 9999px;
    }
    .hc-view-profile-btn:hover { background: rgba(35, 42, 54, 0.06); }
    .hc-view-profile-btn svg { width: 16px; height: 16px; }

    .hc-patient-detail { font-size: 14px; color: #4A5666; line-height: 142%; }

    .hc-appt-time-block { display: flex; flex-direction: column; align-items: flex-end; gap: 2px; flex-shrink: 0; }
    .hc-appt-time-row { display: flex; align-items: center; gap: 6px; }
    .hc-appt-time-row svg { width: 16px; height: 16px; color: #4A5666; }
    .hc-appt-time-text { font-size: 14px; color: #4A5666; }
    .hc-appt-time-label { font-size: 14px; color: #4A5666; }

    /* Info cards (reason / allergy) */
    .hc-info-card {
        border: 1px solid rgba(23, 56, 99, 0.08);
        border-radius: 12px;
        padding: 16px;
        display: flex;
        align-items: center;
        gap: 16px;
        background: #FFFFFF;
        transition: box-shadow 0.3s ease-in-out, border-color 0.3s ease-in-out;
        cursor: pointer;
    }
    .hc-info-card:hover {
        border-color: rgba(99, 102, 251, 0.15);
        box-shadow: 0px 8px 20px rgba(0, 100, 200, 0.1);
    }

    .hc-info-icon {
        width: 48px; height: 48px; min-width: 48px;
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        transition: filter 0.3s ease-in-out;
    }
    .hc-info-card:hover .hc-info-icon {
        filter: saturate(1.4) brightness(1.05);
    }
    .hc-info-icon svg { width: 22px; height: 22px; }
    .hc-info-icon-blue { background: #D2E2FB; border: 1px solid #D2E2FB; }
    .hc-info-icon-blue svg { color: #6098F2; }
    .hc-info-icon-yellow { background: #FFF4D3; border: 1px solid #FFF4D3; }
    .hc-info-icon-yellow svg { color: #FFD760; }

    .hc-info-text { flex: 1; display: flex; flex-direction: column; }
    .hc-info-label { font-weight: 700; font-size: 16px; line-height: 150%; color: #3D3D3D; }
    .hc-info-desc-row { display: flex; justify-content: space-between; align-items: center; }
    .hc-info-desc { font-size: 14px; color: #4A5666; line-height: 142%; }

    .hc-details-btn {
        display: flex; align-items: center; gap: 4px;
        background: none; border: none; cursor: pointer;
        font-family: 'Poppins', sans-serif;
        font-size: 14px; color: #4A5666; padding: 2px 8px; white-space: nowrap;
    }
    .hc-details-btn:hover { color: #232A36; }
    .hc-details-btn svg { width: 16px; height: 16px; }

    .hc-divider { width: 100%; height: 1px; background: rgba(23, 56, 99, 0.08); margin: 0; }

    /* Daily alerts */
    .hc-alerts-list { padding: 12px 24px 24px; display: flex; flex-direction: column; gap: 16px; overflow-y: auto; flex: 1; }

    .hc-alert-box {
        border-left: 4px solid #CBD5E1;
        border-radius: 8px;
        overflow: hidden;
        transition: box-shadow 0.3s ease-in-out, border-color 0.3s ease-in-out;
        cursor: pointer;
    }
    .hc-alert-box:hover {
        border-left-color: rgba(99, 102, 251, 0.4);
        box-shadow: 0px 8px 20px rgba(0, 100, 200, 0.1);
    }
    .hc-alert-content {
        background: #F1F5F9;
        border-width: 1px 1px 1px 0px;
        border-style: solid;
        border-color: rgba(23, 56, 99, 0.08);
        border-radius: 0px 12px 12px 0px;
        padding: 8px 16px;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }
    .hc-alert-text { font-size: 16px; line-height: 150%; color: #232A36; }
    .hc-alert-meta { display: flex; justify-content: space-between; align-items: center; }
    .hc-alert-time { font-size: 14px; color: #4A5666; }

    .hc-review-btn {
        display: inline-flex; align-items: center; gap: 4px;
        background: none; border: none; cursor: pointer;
        font-family: 'Poppins', sans-serif;
        font-size: 14px; color: #334155; padding: 2px 0 2px 8px;
    }
    .hc-review-btn:hover { color: #232A36; }
    .hc-review-btn svg { width: 16px; height: 16px; }

    /* ========== AI FAB ========== */
    .hc-fab {
        position: fixed; bottom: 40px; right: 40px;
        z-index: 1000;
        width: 68px; height: 68px;
        background: linear-gradient(135deg, #AC58FF 0%, #4B5FFA 100%);
        box-shadow: 0px 10px 12px rgba(0, 0, 0, 0.16), 0px 4px 16px rgba(0, 0, 0, 0.12);
        border-radius: 9999px;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; border: none; color: #FFFFFF;
    }
    .hc-fab:hover { filter: brightness(1.1); }
    .hc-fab svg { width: 24px; height: 24px; }

    /* ========== AI CHAT PANEL ========== */
    .hc-chat-wrapper {
        position: fixed; bottom: 120px; right: 40px;
        width: 400px; height: 560px;
        background: #FFFFFF;
        border-radius: 20px;
        box-shadow: 0px 12px 48px rgba(0, 0, 0, 0.16), 0px 4px 16px rgba(0, 0, 0, 0.08);
        z-index: 1100;
        display: flex; flex-direction: column;
        overflow: hidden;
        font-family: 'Poppins', sans-serif;
    }
    .hc-chat-header {
        padding: 14px 20px;
        background: #FFFFFF;
        color: #232A36;
        display: flex; align-items: center; gap: 10px;
        flex-shrink: 0;
        border-bottom: 1px solid rgba(23, 56, 99, 0.08);
    }
    .hc-chat-header-icon {
        width: 24px; height: 24px; min-width: 24px;
        display: flex; align-items: center; justify-content: center;
    }
    .hc-chat-header-icon svg { width: 20px; height: 20px; }
    .hc-chat-header-text { display: flex; flex-direction: column; flex: 1; }
    .hc-chat-header-title { font-weight: 700; font-size: 15px; line-height: 140%; color: #232A36; }
    .hc-chat-header-sub { display: none; }
    .hc-chat-close {
        background: none; border: none; cursor: pointer;
        color: #94A3B8;
        width: 32px; height: 32px;
        display: flex; align-items: center; justify-content: center;
        border-radius: 8px;
        transition: background 0.2s ease, color 0.2s ease;
    }
    .hc-chat-close:hover { background: rgba(35, 42, 54, 0.06); color: #232A36; }
    .hc-chat-close svg { width: 16px; height: 16px; }

    .hc-chat-welcome {
        text-align: center;
        padding: 24px 20px 8px;
        display: flex; flex-direction: column; align-items: center; gap: 8px;
    }
    .hc-chat-welcome-date {
        font-size: 12px; color: #94A3B8;
        background: #F1F5F9; border-radius: 9999px;
        padding: 4px 12px;
    }
    .hc-chat-welcome-greeting {
        font-size: 14px; color: #232A36; line-height: 160%;
    }
    .hc-chat-welcome-greeting strong { display: block; font-size: 16px; margin-bottom: 4px; }

    /* TelerikChat overrides */
    .hc-chat-wrapper .k-chat {
        border: none;
        border-radius: 0 0 20px 20px;
        font-family: 'Poppins', sans-serif;
        background: #FFFFFF;
    }
    .hc-chat-wrapper .k-chat .k-message-list {
        background: #FFFFFF;
    }
    .hc-chat-wrapper .k-chat .k-bubble {
        border-radius: 16px;
        font-size: 14px;
        line-height: 160%;
        font-family: 'Poppins', sans-serif;
    }
    .hc-chat-wrapper .k-chat .k-message-group-receiver .k-bubble {
        background: #F8FAFC;
        border: 1px solid rgba(23, 56, 99, 0.08);
        color: #232A36;
        border-bottom-left-radius: 4px;
    }
    .hc-chat-wrapper .k-chat .k-message-group-sender .k-bubble {
        background: #2D3655;
        border: none;
        color: #FFFFFF;
        border-bottom-right-radius: 4px;
    }
    .hc-chat-wrapper .k-chat .k-quick-replies .k-quick-reply {
        border-radius: 9999px;
        padding: 8px 14px;
        font-family: 'Poppins', sans-serif;
        font-size: 13px;
        color: #334155;
        border: 1px solid rgba(23, 56, 99, 0.12);
        background: #FFFFFF;
        transition: background 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    }
    .hc-chat-wrapper .k-chat .k-quick-replies .k-quick-reply:hover {
        background: #F1F5F9;
        border-color: rgba(99, 102, 251, 0.3);
        box-shadow: 0px 2px 8px rgba(99, 102, 251, 0.1);
    }
    .hc-chat-wrapper .k-chat .k-message-box-wrapper {
        border-top: 1px solid rgba(23, 56, 99, 0.08);
        padding: 8px 12px;
    }
    .hc-chat-wrapper .k-chat .k-prompt-box {
        font-family: 'Poppins', sans-serif;
        border: 1px solid rgba(23, 56, 99, 0.12);
        border-radius: 12px;
        background: #F9FAFB;
    }
    .hc-chat-wrapper .k-chat .k-prompt-box:focus-within {
        border-color: rgba(99, 102, 251, 0.4);
        box-shadow: 0 0 0 2px rgba(99, 102, 251, 0.1);
    }
    .hc-chat-wrapper .k-chat .k-prompt-box-textarea.k-input-inner {
        font-family: 'Poppins', sans-serif;
        font-size: 14px;
        color: #232A36;
    }
    .hc-chat-wrapper .k-chat .k-suggestion {
        border-radius: 9999px;
    }
    .hc-chat-wrapper .k-chat .k-message-author {
        display: none;
    }
    .hc-chat-wrapper .k-chat .k-timestamp {
        display: none;
    }
    .hc-chat-wrapper .k-chat .k-no-avatar {
        margin-left: 0;
    }

    /* ========== MODAL DIALOGS ========== */
    .hc-modal.k-window {
        border-radius: 20px !important;
        overflow: hidden;
        font-family: 'Poppins', sans-serif;
        box-shadow: 0px 12px 40px rgba(0, 0, 0, 0.12), 0px 4px 12px rgba(0, 0, 0, 0.06);
    }
    .hc-modal .k-window-titlebar {
        padding: 24px 28px 16px;
        background: #FFFFFF;
        border-bottom: none;
        border-radius: 20px 20px 0 0;
    }
    .hc-modal .k-window-titlebar .k-window-title {
        font-size: 20px;
        font-weight: 700;
        color: #232A36;
    }
    .hc-modal .k-window-titlebar .k-window-action {
        color: #94A3B8;
        opacity: 0.7;
    }
    .hc-modal .k-window-titlebar .k-window-action:hover {
        color: #232A36;
        opacity: 1;
        background: transparent;
    }
    .hc-modal .k-window-content {
        padding: 0;
        border-radius: 0 0 20px 20px;
    }
    .hc-modal-body {
        padding: 0 28px 28px;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }
    .hc-modal-field {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    .hc-modal-label {
        font-weight: 500;
        font-size: 14px;
        color: #232A36;
    }
    .hc-modal .k-dropdownlist,
    .hc-modal .k-multiselect,
    .hc-modal .k-textbox {
        border-radius: 10px !important;
        background: #F9FAFB;
        border: 1px solid rgba(23, 56, 99, 0.12);
    }
    .hc-modal .k-dropdownlist:focus-within,
    .hc-modal .k-multiselect:focus-within,
    .hc-modal .k-textbox:focus-within {
        border-color: rgba(99, 102, 251, 0.4);
        box-shadow: 0 0 0 2px rgba(99, 102, 251, 0.1);
    }
    .hc-modal-textarea {
        border-radius: 10px !important;
        background: #F9FAFB;
        border: 1px solid rgba(23, 56, 99, 0.12);
    }
    .hc-modal-textarea:focus-within {
        border-color: rgba(99, 102, 251, 0.4);
        box-shadow: 0 0 0 2px rgba(99, 102, 251, 0.1);
    }
    .hc-modal-textarea .k-input-inner {
        min-height: 160px;
    }
    .hc-modal-popup.k-animation-container {
        border-radius: 10px;
        overflow: hidden;
    }
    .hc-modal-popup .k-list-content,
    .hc-modal-popup .k-popup {
        border-radius: 10px;
    }
    .hc-lab-checklist {
        max-height: 250px;
        overflow-y: auto;
        border: 1px solid rgba(23, 56, 99, 0.08);
        border-radius: 10px;
        background: #FFFFFF;
    }
    .hc-lab-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 16px;
        cursor: pointer;
        border-bottom: 1px solid rgba(23, 56, 99, 0.06);
        transition: box-shadow 0.2s ease-in-out;
    }
    .hc-lab-row:last-child {
        border-bottom: none;
    }
    .hc-lab-row:hover {
        box-shadow: 0px 8px 20px rgba(0, 100, 200, 0.1);
        z-index: 1;
        position: relative;
    }
    .hc-lab-row-selected {
        background: rgba(99, 102, 251, 0.04);
    }
    .hc-lab-check {
        width: 22px;
        height: 22px;
        min-width: 22px;
        border-radius: 50%;
        border: 2px solid #CBD5E1;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.15s ease, border-color 0.15s ease;
    }
    .hc-lab-check svg {
        width: 12px;
        height: 12px;
    }
    .hc-lab-checked {
        background: #334155;
        border-color: #334155;
    }
    .hc-lab-name {
        font-size: 14px;
        color: #232A36;
        line-height: 150%;
    }
    .hc-modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        padding-top: 4px;
    }
    .hc-modal-btn {
        font-family: 'Poppins', sans-serif;
        font-size: 14px;
        font-weight: 500;
        padding: 10px 24px;
        border-radius: 12px;
        cursor: pointer;
        border: none;
        transition: background 0.2s ease;
    }
    .hc-modal-btn-secondary {
        background: transparent;
        color: #4A5666;
