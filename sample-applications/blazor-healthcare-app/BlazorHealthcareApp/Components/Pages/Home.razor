@if (isAIChatOpen)
{
    <div class="hc-chat-wrapper">
        <!-- Header -->
        <div class="hc-chat-header">
            <div class="hc-chat-header-icon">
                <svg viewBox="0 0 20 20" fill="none"><path d="M10 1l1.5 4.5L16 7l-4.5 1.5L10 13l-1.5-4.5L4 7l4.5-1.5L10 1z" fill="#7C5CFC" opacity="0.9"/><path d="M15 11l1 3 3 1-3 1-1 3-1-3-3-1 3-1 1-3z" fill="#7C5CFC" opacity="0.7"/><path d="M4 12l.75 2.25L7 15l-2.25.75L4 18l-.75-2.25L1 15l2.25-.75L4 12z" fill="#7C5CFC" opacity="0.5"/></svg>
            </div>
            <div class="hc-chat-header-text">
                <span class="hc-chat-header-title">AI Assistant</span>
                <span class="hc-chat-header-sub">Powered by Clinical Insights</span>
            </div>
            <button class="hc-chat-close" @onclick="ToggleAIChat">
                <svg viewBox="0 0 16 16" fill="none"><path d="M4 4L12 12M12 4L4 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
        </div>

        <TelerikChat @ref="chatRef"
                     Data="@chatData"
                     AuthorId="@("user")"
                     Suggestions="@chatSuggestions"
                     OnSendMessage="@OnChatSendMessage"
                     OnSuggestionClick="@OnChatSuggestionClick"
                     Placeholder="Type a message"
                     Height="100%"
                     EnableSpeechToText="true"
                     EnableFileUpload="true">
            <ChatSettings>
                <ChatTextAreaSettings Mode="@PromptBoxMode.MultiLine" Rows="3" MaxTextAreaHeight="120px" />
            </ChatSettings>
            <NoDataTemplate>
                <div class="hc-chat-welcome">
                    <span class="hc-chat-welcome-date">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</span>
                    <div class="hc-chat-welcome-greeting">
                        <strong>@("\U0001F44B") Hello! I'm your AI Assistant.</strong>
                        I can help you with your daily clinical tasks, patient information, and quick actions. Try one of the suggestions below!
                    </div>
                </div>
            </NoDataTemplate>
        </TelerikChat>
    </div>
}

@code {
    private bool isAIChatOpen;
    private TelerikChat<AIChatMsg> chatRef = null!;
    private List<AIChatMsg> chatData = new();
    private List<string> chatSuggestions = new() { "Summary for next patient", "Provide lab results" };

    // Quick Action modal state
    private bool isNoteModalOpen;
    private bool isTestModalOpen;
    private bool isMessageModalOpen;

    // Modal form data
    private string selectedPatient = "James Wilson (P-104582)";
    private List<string> patientNames = new() { "James Wilson (P-104582)", "Ava Patel (P-103201)", "Emily Chen (P-105887)", "Alexander Novak (P-102445)" };

    private string noteText = "";

    private List<string> selectedLabTests = new();
    private List<string> labTests = new() { "Complete blood count (CBC)", "Comprehensive metabolic panel (CMP)", "Basic metabolic panel (BMP)", "Lipid panel", "Thyroid function test", "Hemoglobin A1C", "Urinalysis", "Chest X-Ray", "MRI" };

    private void ToggleLabTest(string test)
    {
        if (selectedLabTests.Contains(test))
        {
            selectedLabTests.Remove(test);
        }
        else
        {
            selectedLabTests.Add(test);
        }
