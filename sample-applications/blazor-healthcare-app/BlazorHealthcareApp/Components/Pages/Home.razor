@page "/"
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject AppointmentService AppointmentService
@inject AlertService AlertService
@inject StaffService StaffService
@inject PatientService PatientService

<!-- ========== HEADING ========== -->
    <div class="hc-heading">
        <h1>Good morning, Dr. Carter</h1>
        <p>Today is @DateTime.Now.ToString("dddd, MMMM, dd, yyyy")</p>
    </div>

    <!-- ========== MAIN 2-COL ========== -->
    <div class="hc-main">
        <!-- LEFT COLUMN -->
        <div class="hc-left">
            <!-- Quick Actions -->
            <div class="hc-card">
                <div class="hc-card-title">Quick Actions</div>
                <div class="hc-quick-actions">
                    <div class="hc-qa-card">
                        <div class="hc-qa-icon">
                            <svg class="shortcut-icon" width="42" height="42" viewBox="0 0 42 42" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <g>
                                    <path d="M23.45 3.5H10.5C9.57174 3.5 8.6815 3.86875 8.02513 4.52513C7.36875 5.1815 7 6.07174 7 7V35C7 35.9283 7.36875 36.8185 8.02513 37.4749C8.6815 38.1313 9.57174 38.5 10.5 38.5H31.5C32.4283 38.5 33.3185 38.1313 33.9749 37.4749C34.6313 36.8185 35 35.9283 35 35V22.05" stroke="#6366FB" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
                                    <path d="M3.5 10.5H10.5" stroke="#6366FB" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
                                    <path d="M3.5 17.5H10.5" stroke="#6366FB" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
                                    <path d="M3.5 24.5H10.5" stroke="#6366FB" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
                                    <path d="M3.5 31.5H10.5" stroke="#6366FB" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
                                    <path d="M37.4115 9.84527C38.1086 9.14815 38.5002 8.20265 38.5002 7.21677C38.5002 6.23089 38.1086 5.28539 37.4115 4.58827C36.7143 3.89115 35.7688 3.49951 34.783 3.49951C33.7971 3.49951 32.8516 3.89115 32.1545 4.58827L23.387 13.3593C22.9709 13.7751 22.6663 14.2891 22.5015 14.8538L21.0367 19.8763C20.9928 20.0269 20.9902 20.1865 21.0291 20.3384C21.068 20.4904 21.1471 20.6291 21.258 20.74C21.3689 20.8509 21.5076 20.93 21.6595 20.9689C21.8115 21.0078 21.9711 21.0052 22.1217 20.9613L27.1442 19.4965C27.7089 19.3316 28.2229 19.0271 28.6387 18.611L37.4115 9.84527Z" stroke="#6366FB" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
                                </g>
                            </svg>
                        </div>
                        <div class="hc-qa-header">
                            <div class="hc-qa-title">Add new clinical note</div>
                            <div class="hc-qa-subtitle">Clinical text overview</div>
                        </div>
                        <div class="hc-qa-footer">
                            <button class="hc-qa-plus" @onclick="() => IsNoteModalOpen = true">
                                <svg viewBox="0 0 16 16" fill="none"><line x1="3.33" y1="8" x2="12.67" y2="8" stroke="white" stroke-width="1.33" stroke-linecap="round"/><line x1="8" y1="3.33" x2="8" y2="12.67" stroke="white" stroke-width="1.33" stroke-linecap="round"/></svg>
                                <span class="hc-qa-btn-text">Add note</span>
                            </button>
                        </div>
                    </div>

                    <div class="hc-qa-card">
                        <div class="hc-qa-icon">
                            <svg class="shortcut-icon" width="42" height="42" viewBox="0 0 42 42" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <g>
                                    <path d="M24.5 3.5V14C24.4997 14.5871 24.6471 15.1648 24.9287 15.68L34.5712 33.32C34.8629 33.8531 35.0107 34.4529 35.0002 35.0604C34.9898 35.668 34.8213 36.2623 34.5114 36.785C34.2015 37.3077 33.7608 37.7407 33.2328 38.0414C32.7048 38.3421 32.1076 38.5001 31.5 38.5H10.5C9.89232 38.5001 9.29511 38.3421 8.76709 38.0414C8.23907 37.7407 7.79844 37.3077 7.48854 36.785C7.17864 36.2623 7.01016 35.668 6.99967 35.0604C6.98918 34.4529 7.13704 33.8531 7.42871 33.32L17.0712 15.68C17.3528 15.1648 17.5002 14.5871 17.5 14V3.5" stroke="#6366FB" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
                                    <path d="M11.2927 26.25H30.7072" stroke="#6366FB" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
                                    <path d="M14.875 3.5H27.125" stroke="#6366FB" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
                                </g>
                            </svg>
                        </div>
                        <div class="hc-qa-header">
                            <div class="hc-qa-title">Request lab test</div>
                            <div class="hc-qa-subtitle">Request information</div>
                        </div>
                        <div class="hc-qa-footer">
                            <button class="hc-qa-plus" @onclick="() => IsTestModalOpen = true">
                                <svg viewBox="0 0 16 16" fill="none"><line x1="3.33" y1="8" x2="12.67" y2="8" stroke="white" stroke-width="1.33" stroke-linecap="round"/><line x1="8" y1="3.33" x2="8" y2="12.67" stroke="white" stroke-width="1.33" stroke-linecap="round"/></svg>
                                <span class="hc-qa-btn-text">Request test</span>
                            </button>
                        </div>
                    </div>

                    <div class="hc-qa-card">
                        <div class="hc-qa-icon">
                            <TelerikSvgIcon Icon="@SvgIcon.Comment" />
                        </div>
                        <div class="hc-qa-header">
                            <div class="hc-qa-title">Message nurse</div>
                            <div class="hc-qa-subtitle">Communication note</div>
                        </div>
                        <div class="hc-qa-footer">
                            <button class="hc-qa-plus" @onclick="() => IsMessageModalOpen = true">
                                <svg viewBox="0 0 16 16" fill="none"><line x1="3.33" y1="8" x2="12.67" y2="8" stroke="white" stroke-width="1.33" stroke-linecap="round"/><line x1="8" y1="3.33" x2="8" y2="12.67" stroke="white" stroke-width="1.33" stroke-linecap="round"/></svg>
                                <span class="hc-qa-btn-text">Send message</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Today's Appointments -->
            <div class="hc-card" style="flex: 1; display: flex; flex-direction: column;">
                <div class="hc-appt-header">
                    <div class="hc-card-title">Today's Appointments</div>
                    <a href="./schedule" class="hc-view-schedule-btn">
                        <svg viewBox="0 0 16 16" fill="none"><line x1="3.33" y1="8" x2="12.67" y2="8" stroke="white" stroke-width="1.33" stroke-linecap="round"/><line x1="8" y1="3.33" x2="8" y2="12.67" stroke="white" stroke-width="1.33" stroke-linecap="round"/></svg>
                        View Schedule
                    </a>
                </div>
                <div class="hc-grid-wrapper" style="flex: 1;">
                    <TelerikGrid Data="@Appointments">
                        <GridColumns>
                            <GridColumn Title="Time" Width="120px">
                            <Template>
                                @{
                                    var appt = (Appointment)context;
                                }
                                @appt.Start.ToString("h:mm tt")
                            </Template>
                        </GridColumn>
                            <GridColumn Field="@nameof(Appointment.PatientName)" Title="Patient Name" Width="160px" />
                            <GridColumn Field="@nameof(Appointment.Description)" Title="Reason" />
                            <GridColumn Field="@nameof(Appointment.Status)" Title="Status" Width="150px">
                                <Template>
                                    @{
                                        var appt = (Appointment)context;
                                        var badgeClass = appt.Status switch
                                        {
                                            AppointmentStatus.Complete => "hc-badge-complete",
                                            AppointmentStatus.InProgress => "hc-badge-inprogress",
                                            AppointmentStatus.Upcoming => "hc-badge-upcoming",
                                            AppointmentStatus.Cancelled => "hc-badge-cancelled",
                                            _ => "hc-badge-complete"
                                        };
                                    }
                                    <span class="hc-badge @badgeClass">@appt.Status</span>
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(Appointment.Room)" Title="Room" Width="120px" />
                        </GridColumns>
                    </TelerikGrid>
                </div>
            </div>
        </div>

        <!-- RIGHT COLUMN -->
        <div class="hc-right">
            <div class="hc-right-card">
                <!-- Next Patient -->
                <div class="hc-right-section-header">Next Patient</div>
                <div class="hc-next-patient">
                    <div class="hc-patient-row">
                        <div class="hc-patient-info">
                            <div class="hc-patient-avatar">
                                <img src="images/james-wilson.jpg" alt="James Wilson" style="width:100%;height:100%;object-fit:cover;" />
                            </div>
                            <div class="hc-patient-name-block">
                                <div class="hc-patient-name-row">
                                    <span class="hc-patient-name">James Wilson</span>
                                    <TelerikButton OnClick="@GoToPatientProfile" Class="hc-view-profile-btn" FillMode="@ThemeConstants.Button.FillMode.Flat" Icon="@SvgIcon.HyperlinkOpen">View profile</TelerikButton>
                                </div>
                                <span class="hc-patient-detail">44 years, Male</span>
                            </div>
                        </div>
                        <div class="hc-appt-time-block">
                            <div class="hc-appt-time-row">
                                <TelerikSvgIcon Icon="@SvgIcon.Clock" />
                                <span class="hc-appt-time-text">11:00 AM</span>
                            </div>
                            <span class="hc-appt-time-label">Appointment time</span>
                        </div>
                    </div>

                    <div class="hc-info-card" @onclick="() => IsReasonForVisitOpen = true" style="cursor:pointer;"> 
                        <div class="hc-info-icon hc-info-icon-blue">
                            <svg viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <rect x="3" y="5" width="16" height="14" rx="2" stroke="#6098F2" stroke-width="2"/>
                                <line x1="11" y1="9" x2="11" y2="13" stroke="#6098F2" stroke-width="2" stroke-linecap="round"/>
                                <line x1="9" y1="11" x2="13" y2="11" stroke="#6098F2" stroke-width="2" stroke-linecap="round"/>
                                <line x1="5" y1="5" x2="5" y2="2" stroke="#6098F2" stroke-width="2" stroke-linecap="round"/>
                                <line x1="17" y1="5" x2="17" y2="2" stroke="#6098F2" stroke-width="2" stroke-linecap="round"/>
                            </svg>
                        </div>
                        <div class="hc-info-text">
                            <span class="hc-info-label">Reason for visit</span>
                            <div class="hc-info-desc-row">
                                <span class="hc-info-desc">Persistent cough and chest congestion</span>
                                <button class="hc-details-btn" @onclick="() => IsReasonForVisitOpen = true" @onclick:stopPropagation="true">
                                    Details
                                    <TelerikSvgIcon Icon="@SvgIcon.ChevronRight" />
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="hc-info-card" @onclick="() => IsAllergyAlertOpen = true" style="cursor:pointer;">
                        <div class="hc-info-icon hc-info-icon-yellow">
                            <svg viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="11" cy="11" r="9" stroke="#FFD760" stroke-width="2"/>
                                <circle cx="11" cy="11" r="3" stroke="#FFD760" stroke-width="2"/>
                            </svg>
                        </div>
                        <div class="hc-info-text">
                            <span class="hc-info-label">Allergy Alert</span>
                            <div class="hc-info-desc-row">
                                <span class="hc-info-desc">Penicillin</span>
                                <button class="hc-details-btn" @onclick="() => IsAllergyAlertOpen = true" @onclick:stopPropagation="true">
                                    Details
                                    <TelerikSvgIcon Icon="@SvgIcon.ChevronRight" />
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="hc-divider" style="margin: 0 20px;"></div>

                <!-- Daily Alerts -->
                <div class="hc-right-section-header">Daily Alerts</div>
                <div class="hc-alerts-list">
                    @foreach (var alert in DailyAlerts)
                    {
                        <div class="hc-alert-box" @onclick="() => OpenAlertDialog(alert)" style="cursor:pointer;">
                            <div class="hc-alert-content">
                                <span class="hc-alert-text">@alert.Text</span>
                                <div class="hc-alert-meta">
                                    <span class="hc-alert-time">@GetRelativeTime(alert.Timestamp)</span>
                                    <button class="hc-review-btn" @onclick="() => OpenAlertDialog(alert)" @onclick:stopPropagation="true">
                                        Review
                                        <svg viewBox="0 0 16 16" fill="none"><path d="M5 3L10 8L5 13" stroke="#334155" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

<!-- ========== QUICK ACTION MODALS ========== -->
<TelerikWindow @bind-Visible="@IsNoteModalOpen" Modal="true" Width="520px" Class="hc-modal">
    <WindowTitle>
        <strong>New Clinical Note</strong>
    </WindowTitle>
    <WindowActions>
        <WindowAction Name="Close" />
    </WindowActions>
    <WindowContent>
        <div class="hc-modal-body">
            <div class="hc-modal-field">
                <label class="hc-modal-label">Select Patient</label>
                <TelerikDropDownList Data="@PatientNames" @bind-Value="@SelectedPatient" Width="240px">
                    <DropDownListSettings>
                        <DropDownListPopupSettings Class="hc-modal-popup" />
                    </DropDownListSettings>
                </TelerikDropDownList>
            </div>
            <div class="hc-modal-field">
                <label class="hc-modal-label">Clinical Note</label>
                <TelerikTextArea @bind-Value="@NoteText" Width="100%" PlaceHolder="Add clinical notes, observations, treatment plans, etc." ResizeMode="@TextAreaResizeMode.None" Class="hc-modal-textarea k-h-full" />
            </div>
            <div class="hc-modal-actions">
                <button class="hc-modal-btn hc-modal-btn-secondary" @onclick="() => IsNoteModalOpen = false">Discard</button>
                <button class="hc-modal-btn hc-modal-btn-primary" @onclick="() => IsNoteModalOpen = false">Save note</button>
            </div>
        </div>
    </WindowContent>
</TelerikWindow>

<TelerikWindow @bind-Visible="@IsTestModalOpen" Modal="true" Width="520px" Class="hc-modal">
    <WindowTitle>
        <strong>Request Lab Tests</strong>
    </WindowTitle>
    <WindowActions>
        <WindowAction Name="Close" />
    </WindowActions>
    <WindowContent>
        <div class="hc-modal-body">
            <div class="hc-modal-field">
                <label class="hc-modal-label">Select Patient</label>
                <TelerikDropDownList Data="@PatientNames" @bind-Value="@SelectedPatient" Width="240px">
                    <DropDownListSettings>
                        <DropDownListPopupSettings Class="hc-modal-popup" />
                    </DropDownListSettings>
                </TelerikDropDownList>
            </div>
            <div class="hc-modal-field">
                <label class="hc-modal-label">Select Lab Tests</label>
                <TelerikMultiSelect Data="@LabTests" @bind-Value="@SelectedLabTests" Width="100%" Placeholder="Search Lab Tests" AutoClose="false">
                    <MultiSelectSettings>
                        <MultiSelectPopupSettings Class="hc-modal-popup" />
                    </MultiSelectSettings>
                </TelerikMultiSelect>
            </div>
            <div class="hc-lab-checklist">
                @foreach (var test in LabTests)
                {
                    <div class="hc-lab-row @(SelectedLabTests.Contains(test) ? "hc-lab-row-selected" : "")" @onclick="() => ToggleLabTest(test)">
                        <div class="hc-lab-check @(SelectedLabTests.Contains(test) ? "hc-lab-checked" : "")">
                            @if (SelectedLabTests.Contains(test))
                            {
                                <svg viewBox="0 0 12 12" fill="none"><path d="M2.5 6L5 8.5L9.5 3.5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            }
                        </div>
                        <span class="hc-lab-name">@test</span>
                    </div>
                }
            </div>
            <div class="hc-modal-actions">
                <button class="hc-modal-btn hc-modal-btn-secondary" @onclick="() => IsTestModalOpen = false">Discard</button>
                <button class="hc-modal-btn hc-modal-btn-primary" @onclick="() => IsTestModalOpen = false">Send request</button>
            </div>
        </div>
    </WindowContent>
</TelerikWindow>

<TelerikWindow @bind-Visible="@IsMessageModalOpen" Modal="true" Width="520px" Class="hc-modal">
    <WindowTitle>
        <strong>Message Nurse</strong>
    </WindowTitle>
    <WindowActions>
        <WindowAction Name="Close" />
    </WindowActions>
    <WindowContent>
        <div class="hc-modal-body">
            <div class="hc-modal-field">
                <label class="hc-modal-label">To</label>
                <TelerikDropDownList Data="@NurseRecipients" Value="@SelectedNurse" ValueChanged="@((string v) => OnNurseChanged(v))" Width="240px">
                    <DropDownListSettings>
                        <DropDownListPopupSettings Class="hc-modal-popup" />
                    </DropDownListSettings>
                </TelerikDropDownList>
            </div>
            <div class="hc-modal-field">
                <label class="hc-modal-label">Subject</label>
                <TelerikTextBox @bind-Value="@MessageSubject" Width="100%" PlaceHolder="Enter subject" />
            </div>
            <div class="hc-modal-field">
                <label class="hc-modal-label">Description</label>
                <TelerikTextArea @bind-Value="@MessageText" Width="100%" ResizeMode="@TextAreaResizeMode.None" PlaceHolder="Write your message here..." Class="hc-modal-textarea k-h-full" />
            </div>
            <div class="hc-modal-actions">
                <button class="hc-modal-btn hc-modal-btn-secondary" @onclick="() => IsMessageModalOpen = false">Discard</button>
                <button class="hc-modal-btn hc-modal-btn-primary" @onclick="() => IsMessageModalOpen = false">Send message</button>
            </div>
        </div>
    </WindowContent>
</TelerikWindow>

<!-- ========== ALLERGY ALERT DIALOG ========== -->
<TelerikWindow @bind-Visible="@IsAllergyAlertOpen" Modal="true" Width="700px" Class="hc-detail-dialog">
    <WindowTitle>
        <span class="hc-dlg-title">⚠️ Critical Allergy Alert</span>
    </WindowTitle>
    <WindowActions>
        <WindowAction Name="Close" />
    </WindowActions>
    <WindowContent>
        <div class="hc-dlg-content">
            <div class="hc-dlg-section">
                <h3 class="hc-dlg-section-label">Patient & Allergen</h3>
                <div class="hc-dlg-info-grid">
                    <div class="hc-dlg-info-item">
                        <span class="hc-dlg-info-label">Patient Name:</span>
                        <span class="hc-dlg-info-value">Isabella Rossi</span>
                    </div>
                    <div class="hc-dlg-info-item">
                        <span class="hc-dlg-info-label">Patient ID:</span>
                        <span class="hc-dlg-info-value">P-102563</span>
                    </div>
                    <div class="hc-dlg-info-item">
                        <span class="hc-dlg-info-label">Allergen:</span>
                        <span class="hc-dlg-info-value">Penicillin</span>
                    </div>
                    <div class="hc-dlg-info-item">
                        <span class="hc-dlg-info-label">First Reported:</span>
                        <span class="hc-dlg-info-value">March 2018</span>
                    </div>
                </div>
            </div>

            <div class="hc-dlg-section">
                <h3 class="hc-dlg-section-label">Severity & Reaction Type</h3>
                <div class="hc-dlg-info-grid">
                    <div class="hc-dlg-info-item">
                        <span class="hc-dlg-info-label">Severity Level:</span>
                        <span class="hc-dlg-info-value hc-dlg-value-critical">Severe</span>
                    </div>
                    <div class="hc-dlg-info-item">
                        <span class="hc-dlg-info-label">Reaction Type:</span>
                        <span class="hc-dlg-info-value hc-dlg-value-critical">Anaphylaxis</span>
                    </div>
                </div>
            </div>

            <div class="hc-dlg-section">
                <h3 class="hc-dlg-section-label">Reported Symptoms</h3>
                <ul class="hc-dlg-list">
                    <li class="hc-dlg-list-item">Difficulty breathing and wheezing</li>
                    <li class="hc-dlg-list-item">Severe skin rash and hives</li>
                    <li class="hc-dlg-list-item">Swelling of face, lips, and throat</li>
                    <li class="hc-dlg-list-item">Rapid pulse and dizziness</li>
                    <li class="hc-dlg-list-item">Loss of consciousness (reported in initial episode)</li>
                </ul>
            </div>

            <div class="hc-dlg-section">
                <h3 class="hc-dlg-section-label">Cross-Reactivities (Avoid)</h3>
                <ul class="hc-dlg-list">
                    <li class="hc-dlg-list-item">Amoxicillin</li>
                    <li class="hc-dlg-list-item">Ampicillin</li>
                    <li class="hc-dlg-list-item">Other beta-lactam antibiotics</li>
                    <li class="hc-dlg-list-item">Possibly cephalosporins (use with caution)</li>
                </ul>
            </div>

            <div class="hc-dlg-section">
                <h3 class="hc-dlg-section-label">Safe Alternatives</h3>
                <ul class="hc-dlg-list">
                    <li class="hc-dlg-list-item">Fluoroquinolones (e.g., Levofloxacin, Ciprofloxacin)</li>
                    <li class="hc-dlg-list-item">Macrolides (e.g., Azithromycin, Clarithromycin)</li>
                    <li class="hc-dlg-list-item">Tetracyclines (e.g., Doxycycline)</li>
                    <li class="hc-dlg-list-item">Vancomycin for severe infections</li>
                </ul>
            </div>

            <div class="hc-dlg-section">
                <h3 class="hc-dlg-section-label">Additional Notes</h3>
                <p class="hc-dlg-text-block">Patient carries EpiPen at all times. Family members are trained in emergency response. Allergy documented in all medical records and patient wears medical alert bracelet.</p>
            </div>
        </div>

        <div class="hc-dlg-actions">
            <button class="hc-modal-btn hc-modal-btn-secondary" @onclick="() => IsAllergyAlertOpen = false">Close</button>
            <button class="hc-modal-btn hc-modal-btn-primary" @onclick="() => IsAllergyAlertOpen = false">Acknowledge</button>
        </div>
    </WindowContent>
</TelerikWindow>

<!-- ========== REASON FOR VISIT DIALOG ========== -->
<TelerikWindow @bind-Visible="@IsReasonForVisitOpen" Modal="true" Width="700px" Class="hc-detail-dialog">
    <WindowTitle>
        <span class="hc-dlg-title">Visit Details</span>
    </WindowTitle>
    <WindowActions>
        <WindowAction Name="Close" />
    </WindowActions>
    <WindowContent>
        <div class="hc-dlg-content">
            <div class="hc-dlg-section">
                <h3 class="hc-dlg-section-label">Patient & Appointment</h3>
                <div class="hc-dlg-info-grid">
                    <div class="hc-dlg-info-item">
                        <span class="hc-dlg-info-label">Patient Name:</span>
                        <span class="hc-dlg-info-value">Isabella Rossi</span>
                    </div>
                    <div class="hc-dlg-info-item">
                        <span class="hc-dlg-info-label">Patient ID:</span>
                        <span class="hc-dlg-info-value">P-102563</span>
                    </div>
                    <div class="hc-dlg-info-item">
                        <span class="hc-dlg-info-label">Appointment:</span>
                        <span class="hc-dlg-info-value">May 8, 2026 at 11:00 AM</span>
                    </div>
                    <div class="hc-dlg-info-item">
                        <span class="hc-dlg-info-label">Visit Type:</span>
                        <span class="hc-dlg-info-value">Cardiology Follow-up</span>
                    </div>
                </div>
            </div>

            <div class="hc-dlg-section">
                <h3 class="hc-dlg-section-label">Primary Concern</h3>
                <span class="hc-dlg-concern-badge">Persistent cough and chest congestion</span>
            </div>

            <div class="hc-dlg-section">
                <h3 class="hc-dlg-section-label">Background</h3>
                <p class="hc-dlg-text-block">Patient has been experiencing persistent dry cough and mild chest congestion for approximately 2 weeks. Symptoms worsen at night and with physical exertion. No fever or significant weight loss reported. Previous history of mild asthma in childhood.</p>
            </div>

            <div class="hc-dlg-section">
                <h3 class="hc-dlg-section-label">Previous Visits</h3>
                <ul class="hc-dlg-list">
                    <li class="hc-dlg-list-item"><strong>Jan 15, 2026:</strong> Annual cardiac check-up — all vitals normal</li>
                    <li class="hc-dlg-list-item"><strong>Sep 22, 2025:</strong> Follow-up on elevated cholesterol — medication adjusted</li>
                    <li class="hc-dlg-list-item"><strong>Mar 10, 2025:</strong> Routine blood work and ECG — no abnormalities</li>
                </ul>
            </div>

            <div class="hc-dlg-section">
                <h3 class="hc-dlg-section-label">Visit Objectives</h3>
                <ul class="hc-dlg-list">
                    <li class="hc-dlg-list-item">Evaluate persistent cough and determine underlying cause</li>
                    <li class="hc-dlg-list-item">Review current medication regimen for potential side effects</li>
                    <li class="hc-dlg-list-item">Order chest X-ray and pulmonary function test if indicated</li>
                    <li class="hc-dlg-list-item">Assess cardiovascular status and update treatment plan</li>
                </ul>
            </div>
        </div>

        <div class="hc-dlg-actions">
            <button class="hc-modal-btn hc-modal-btn-secondary" @onclick="() => IsReasonForVisitOpen = false">Close</button>
            <button class="hc-modal-btn hc-modal-btn-primary" @onclick="() => IsReasonForVisitOpen = false">Start Visit</button>
        </div>
    </WindowContent>
</TelerikWindow>

<!-- ========== ALERT REVIEW DIALOG ========== -->
<TelerikWindow @bind-Visible="@IsAlertDialogOpen" Modal="true" Width="700px" Class="hc-detail-dialog">
    <WindowTitle>
        <span class="hc-dlg-title">Clinical Alert Details</span>
    </WindowTitle>
    <WindowActions>
        <WindowAction Name="Close" />
    </WindowActions>
    <WindowContent>
        @if (SelectedAlert != null)
        {
            <div class="hc-dlg-content">
                <div class="hc-dlg-section">
                    <h3 class="hc-dlg-section-label">Patient Information</h3>
                    <div class="hc-dlg-info-grid">
                        <div class="hc-dlg-info-item">
                            <span class="hc-dlg-info-label">Patient Name:</span>
                            <span class="hc-dlg-info-value">@SelectedAlert.Patient</span>
                        </div>
                        <div class="hc-dlg-info-item">
                            <span class="hc-dlg-info-label">Patient ID:</span>
                            <span class="hc-dlg-info-value">@SelectedAlert.PatientId</span>
                        </div>
                    </div>
                </div>

                <div class="hc-dlg-section">
                    <h3 class="hc-dlg-section-label">Condition</h3>
                    <span class="hc-dlg-concern-badge @(SelectedAlert.Priority == "High" ? "hc-dlg-badge-high" : "")">@SelectedAlert.Condition</span>
                </div>

                <div class="hc-dlg-section">
                    <h3 class="hc-dlg-section-label">Lab Values</h3>
                    <div class="hc-dlg-info-grid">
                        <div class="hc-dlg-info-item">
                            <span class="hc-dlg-info-label">Current Value:</span>
                            <span class="hc-dlg-info-value hc-dlg-value-critical">@SelectedAlert.Value</span>
                        </div>
                        <div class="hc-dlg-info-item">
                            <span class="hc-dlg-info-label">Normal Range:</span>
                            <span class="hc-dlg-info-value">@SelectedAlert.NormalRange</span>
                        </div>
                    </div>
                </div>

                <div class="hc-dlg-section">
                    <h3 class="hc-dlg-section-label">Details</h3>
                    <p class="hc-dlg-text-block">@SelectedAlert.Details</p>
                </div>

                <div class="hc-dlg-section">
                    <h3 class="hc-dlg-section-label">Recommended Actions</h3>
                    <ul class="hc-dlg-list">
                        @foreach (var rec in SelectedAlert.Recommendations)
                        {
                            <li class="hc-dlg-list-item">@rec</li>
                        }
                    </ul>
                </div>
            </div>

            <div class="hc-dlg-actions">
                <button class="hc-modal-btn hc-modal-btn-secondary" @onclick="() => IsAlertDialogOpen = false">Close</button>
                <button class="hc-modal-btn hc-modal-btn-primary" @onclick="() => IsAlertDialogOpen = false">Acknowledge</button>
            </div>
        }
    </WindowContent>
</TelerikWindow>

<!-- ========== AI CHAT ========== -->
<AIChat ShowFab="true"
        WrapperClass="hc-chat-wrapper" />

@code {
    #region Fields

    private void GoToPatientProfile() => Nav.NavigateTo("./patient/1");

    // Quick Action modal state
    private bool IsNoteModalOpen { get; set; }
    private bool IsTestModalOpen { get; set; }
    private bool IsMessageModalOpen { get; set; }

    // Detail dialog state
    private bool IsAllergyAlertOpen { get; set; }
    private bool IsReasonForVisitOpen { get; set; }
    private bool IsAlertDialogOpen { get; set; }
    private DailyAlert? SelectedAlert { get; set; }

    // Modal form data
    private string SelectedPatient { get; set; } = "James Wilson (P-000001)";
    private List<string> PatientNames { get; set; } = new();

    private string NoteText { get; set; } = "";

    private List<string> SelectedLabTests { get; set; } = new();
    private List<string> LabTests { get; set; } = new();

    private string SelectedNurse { get; set; } = "oliviaparker@email.com";
    private List<string> NurseRecipients { get; set; } = new();
    private string MessageSubject { get; set; } = "";
    private string MessageText { get; set; } = "";

    private List<Appointment> Appointments { get; set; } = new();
    private List<DailyAlert> DailyAlerts { get; set; } = new();

    #endregion

    #region Lifecycle

    protected override void OnInitialized()
    {
        Appointments    = AppointmentService.GetAllAppointments().Take(10).ToList();
        DailyAlerts     = AlertService.GetDailyAlerts();
        PatientNames    = PatientService.GetPatients().Select(p => $"{p.Name} (P-{p.Id:D6})").ToList();
        LabTests        = StaffService.GetLabTests();
        NurseRecipients = StaffService.GetNurseRecipients();
        (MessageSubject, MessageText) = StaffService.GetNurseMessageTemplate(SelectedNurse);
    }

    #endregion

    #region Helpers

    private void ToggleLabTest(string test)
    {
        if (SelectedLabTests.Contains(test)) SelectedLabTests.Remove(test);
        else SelectedLabTests.Add(test);
    }

    private void OnNurseChanged(string nurse)
    {
        SelectedNurse = nurse;
        (MessageSubject, MessageText) = StaffService.GetNurseMessageTemplate(nurse);
    }

    private static string GetRelativeTime(DateTime timestamp)
    {
        var diff = DateTime.Now - timestamp;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} min ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} h ago";
        return $"{(int)diff.TotalDays} d ago";
    }

    private void OpenAlertDialog(DailyAlert alert)
    {
        SelectedAlert = alert;
        IsAlertDialogOpen = true;
    }

    #endregion
}

